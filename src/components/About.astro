---
import { getAboutContent, urlFor } from '../lib/sanity'

const about = await getAboutContent()

const imageUrl = about?.image
  ? urlFor(about.image).width(800).height(600).format('webp').url()
  : 'https://images.unsplash.com/photo-1600891964092-4316c288032e?w=800&q=80'

const imageAlt = about?.imageAlt ?? 'Guía turístico con viajeros en los Andes'
---

<section id='nosotros' class='py-16 md:py-24 bg-[var(--color-surface)]'>
  <div class='max-w-7xl mx-auto px-4 md:px-6 grid md:grid-cols-2 gap-10 md:gap-16 items-center'>
    <!-- Text -->
    <div>
      <p
        class='text-[var(--color-primary)] text-sm font-medium tracking-widest uppercase mb-3'
      >
        Nuestra historia
      </p>
      <h2
        class='font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-[var(--color-text)] leading-tight mb-6 reveal'
      >
        {about?.title ?? 'Expertos en turismo andino'}
      </h2>
      <p class='text-[var(--color-muted)] text-base leading-relaxed mb-5 reveal reveal-delay-1'>
        {about?.description ?? `Somos una agencia de turismo comprometida con brindarte experiencias auténticas en los Andes peruanos. Nuestros guías locales certificados te llevarán a descubrir Machu Picchu, el Valle Sagrado y mucho más.`}
      </p>
      <!-- Stats: agregá estadísticas desde Sanity Studio cuando las configures -->
    </div>

    <!-- Image -->
    <div class='relative'>
      <img
        src={imageUrl}
        alt={imageAlt}
        class='w-full h-[280px] sm:h-[380px] md:h-[500px] object-cover rounded-sm shadow-lg max-w-full reveal reveal-delay-2'
        loading='lazy'
      />
      <div
        class='absolute -bottom-6 -left-6 bg-[var(--color-primary)] text-white p-6 w-40 hidden md:block'
      >
        <p class='font-serif text-3xl font-bold'>★★★</p>
        <p class='text-xs mt-1 leading-snug'>
          Premiado por la Guía Gastronómica Nacional
        </p>
      </div>
    </div>
  </div>
</section>
