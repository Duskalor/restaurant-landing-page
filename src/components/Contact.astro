---
import { getContactContent } from '../lib/sanity'

const contact = await getContactContent()

const title = contact?.title ?? 'Consultá tu tour'
const subtitle = contact?.subtitle ?? 'Hablemos'
const phone = contact?.phone ?? '+51 984 123 456'
const email = contact?.email ?? 'hola@cuscotours.pe'
const address = contact?.address ?? 'Calle Plateros 321, Centro Histórico\nCusco, Perú 08002'
const reservationCtaText = contact?.reservationCtaText ?? 'Enviar consulta'

// Parse opening hours: each line "Día | Hora", fallback to hardcoded
const defaultHours = [
  { day: 'Lunes – Viernes', time: '8:00 am – 7:00 pm' },
  { day: 'Sábado', time: '8:00 am – 5:00 pm' },
  { day: 'Domingo', time: '9:00 am – 2:00 pm' },
]

const hours = contact?.openingHours
  ? contact.openingHours
      .split('\n')
      .map((line) => line.trim())
      .filter(Boolean)
      .map((line) => {
        const [day, time] = line.split('|').map((s) => s.trim())
        return { day: day ?? line, time: time ?? '' }
      })
  : defaultHours

// Split address into lines for display
const addressLines = address.split('\n').map((l) => l.trim()).filter(Boolean)
---

<style>
  .flatpickr-calendar {
    font-family: Georgia, serif;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    background: var(--color-bg);
  }
  .flatpickr-months {
    background: var(--color-text);
    border-radius: 4px 4px 0 0;
    padding: 8px 0;
  }
  .flatpickr-month, .flatpickr-prev-month, .flatpickr-next-month {
    color: var(--color-bg) !important;
    fill: var(--color-bg) !important;
  }
  .flatpickr-current-month .flatpickr-monthDropdown-months,
  .flatpickr-current-month input.cur-year {
    color: var(--color-bg);
    font-size: 15px;
  }
  .flatpickr-weekday {
    color: var(--color-primary);
    font-weight: 600;
    font-size: 12px;
  }
  .flatpickr-day {
    color: var(--color-text);
    border-radius: 2px;
  }
  .flatpickr-day:hover {
    background: var(--color-surface);
    border-color: var(--color-primary);
  }
  .flatpickr-day.selected,
  .flatpickr-day.selected:hover {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: #fff;
  }
  .flatpickr-day.today {
    border-color: var(--color-primary);
    color: var(--color-primary);
    font-weight: bold;
  }
  .flatpickr-day.today.selected {
    color: #fff;
  }
  .flatpickr-day.flatpickr-disabled {
    color: var(--color-muted);
  }
</style>

<section id="contacto" class="py-16 md:py-24 bg-[var(--color-surface)]">
  <div class="max-w-7xl mx-auto px-4 md:px-6 grid md:grid-cols-2 gap-10 md:gap-16">
    <!-- Info -->
    <div>
      <p class="text-[var(--color-primary)] text-sm font-medium tracking-widest uppercase mb-3">
        {subtitle}
      </p>
      <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-[var(--color-text)] mb-8 reveal">
        {title}
      </h2>

      <div class="space-y-6 mb-10">
        <div>
          <p class="text-xs text-[var(--color-muted)] uppercase tracking-wider mb-1">Dirección</p>
          {addressLines.map((line, i) => (
            i === 0
              ? <p class="text-[var(--color-text)] font-medium">{line}</p>
              : <p class="text-[var(--color-muted)] text-sm">{line}</p>
          ))}
        </div>
        <div>
          <p class="text-xs text-[var(--color-muted)] uppercase tracking-wider mb-1">Teléfono</p>
          <a href={`tel:${phone.replace(/[\s()\-]/g, '')}`} class="text-[var(--color-text)] font-medium hover:text-[var(--color-primary)] transition-colors">
            {phone}
          </a>
        </div>
        <div>
          <p class="text-xs text-[var(--color-muted)] uppercase tracking-wider mb-1">Correo</p>
          <a href={`mailto:${email}`} class="text-[var(--color-text)] font-medium hover:text-[var(--color-primary)] transition-colors">
            {email}
          </a>
        </div>
      </div>

      <div>
        <p class="text-xs text-[var(--color-muted)] uppercase tracking-wider mb-3">Horarios</p>
        <div class="space-y-2">
          {hours.map((h) => (
            <div class="flex justify-between border-b border-[var(--color-border)] pb-2">
              <span class="text-sm text-[var(--color-text)]">{h.day}</span>
              <span class="text-sm text-[var(--color-muted)]">{h.time}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Form -->
    <div class="bg-white p-6 md:p-10 border border-[var(--color-border)] rounded-sm shadow-sm reveal reveal-delay-1">
      <h3 class="font-serif text-2xl font-bold text-[var(--color-text)] mb-6">Envianos tu consulta</h3>
      <div id="form-success" class="hidden text-center py-8">
        <p class="text-2xl mb-2">✓</p>
        <p class="font-serif text-xl text-[var(--color-text)] mb-1">¡Consulta recibida!</p>
        <p class="text-sm text-[var(--color-muted)]">Te respondemos por correo a la brevedad.</p>
      </div>
      <form id="contact-form" class="space-y-5" novalidate>
        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label for="nombre" class="block text-xs text-[var(--color-muted)] uppercase tracking-wider mb-1.5">Nombre</label>
            <input
              type="text"
              id="nombre"
              name="nombre"
              placeholder="Tu nombre"
              required
              class="w-full px-4 py-2.5 border border-[var(--color-border)] rounded text-sm text-[var(--color-text)] bg-[var(--color-bg)] focus:outline-none focus:border-[var(--color-primary)] transition-colors"
            />
          </div>
          <div>
            <label for="email" class="block text-xs text-[var(--color-muted)] uppercase tracking-wider mb-1.5">Correo</label>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="tu@correo.com"
              required
              class="w-full px-4 py-2.5 border border-[var(--color-border)] rounded text-sm text-[var(--color-text)] bg-[var(--color-bg)] focus:outline-none focus:border-[var(--color-primary)] transition-colors"
            />
          </div>
        </div>
        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label for="fecha" class="block text-xs text-[var(--color-muted)] uppercase tracking-wider mb-1.5">Fecha del tour</label>
            <input
              type="text"
              id="fecha"
              name="fecha"
              placeholder="Seleccioná una fecha"
              required
              readonly
              class="w-full px-4 py-2.5 border border-[var(--color-border)] rounded text-sm text-[var(--color-text)] bg-[var(--color-bg)] focus:outline-none focus:border-[var(--color-primary)] transition-colors cursor-pointer"
            />
          </div>
          <div>
            <label for="personas" class="block text-xs text-[var(--color-muted)] uppercase tracking-wider mb-1.5">Viajeros</label>
            <select
              id="personas"
              name="personas"
              class="w-full px-4 py-2.5 border border-[var(--color-border)] rounded text-sm text-[var(--color-text)] bg-[var(--color-bg)] focus:outline-none focus:border-[var(--color-primary)] transition-colors"
            >
              {[1,2,3,4,5,6,7,8].map((n) => (
                <option value={n}>{n} {n === 1 ? 'viajero' : 'viajeros'}</option>
              ))}
              <option value="9+">9 o más</option>
            </select>
          </div>
        </div>
        <div>
          <label for="mensaje" class="block text-xs text-[var(--color-muted)] uppercase tracking-wider mb-1.5">¿Qué tour te interesa? (opcional)</label>
          <textarea
            id="mensaje"
            name="mensaje"
            rows="3"
            placeholder="Tour al Camino Inca, Machu Picchu, preferencias, preguntas..."
            class="w-full px-4 py-2.5 border border-[var(--color-border)] rounded text-sm text-[var(--color-text)] bg-[var(--color-bg)] focus:outline-none focus:border-[var(--color-primary)] transition-colors resize-none"
          ></textarea>
        </div>
        <p id="form-error" class="hidden text-sm text-red-600"></p>
        <button
          id="submit-btn"
          type="submit"
          class="w-full py-3 bg-[var(--color-primary)] text-white font-medium rounded hover:bg-[var(--color-primary-dark)] transition-colors duration-200 disabled:opacity-60 disabled:cursor-not-allowed"
        >
          {reservationCtaText}
        </button>
      </form>
    </div>
  </div>
</section>

<script>
  import flatpickr from 'flatpickr'
  import 'flatpickr/dist/flatpickr.min.css'
  import { Spanish } from 'flatpickr/dist/l10n/es'

  flatpickr('#fecha', {
    locale: Spanish,
    minDate: 'today',
    dateFormat: 'd/m/Y',
    disableMobile: true,
    onReady(_selectedDates, _dateStr, instance) {
      const cal = instance.calendarContainer
      cal.style.setProperty('--fp-accent', getComputedStyle(document.documentElement).getPropertyValue('--color-primary').trim())
      cal.style.fontFamily = 'Georgia, serif'
    },
  })

  const form = document.getElementById('contact-form') as HTMLFormElement
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement
  const errorEl = document.getElementById('form-error') as HTMLParagraphElement
  const successEl = document.getElementById('form-success') as HTMLDivElement

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    errorEl.classList.add('hidden')
    submitBtn.disabled = true
    submitBtn.textContent = 'Enviando...'

    const res = await fetch('/api/contact', {
      method: 'POST',
      body: new FormData(form),
    })

    const json = await res.json()

    if (res.ok) {
      form.classList.add('hidden')
      successEl.classList.remove('hidden')
    } else {
      errorEl.textContent = json.error ?? 'Error al enviar. Intentá de nuevo.'
      errorEl.classList.remove('hidden')
      submitBtn.disabled = false
      submitBtn.textContent = 'Enviar consulta'
    }
  })
</script>
