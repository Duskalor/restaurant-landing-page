---
import { getContactContent } from '../lib/sanity'

const contact = await getContactContent()

const title = contact?.title ?? 'Reserva tu mesa'
const subtitle = contact?.subtitle ?? 'Encuéntranos'
const phone = contact?.phone ?? null
const email = contact?.email ?? null
const address = contact?.address ?? null
const reservationCtaText = contact?.reservationCtaText ?? 'Confirmar reservación'

// Parse opening hours: each line "Día | Hora", fallback to hardcoded
const defaultHours = [
  { day: 'Lunes – Miércoles', time: '1:00 pm – 10:00 pm' },
  { day: 'Jueves – Viernes', time: '1:00 pm – 11:30 pm' },
  { day: 'Sábado', time: '12:00 pm – 11:30 pm' },
  { day: 'Domingo', time: '12:00 pm – 9:00 pm' },
]

const hours = contact?.openingHours
  ? contact.openingHours
      .split('\n')
      .map((line) => line.trim())
      .filter(Boolean)
      .map((line) => {
        const [day, time] = line.split('|').map((s) => s.trim())
        return { day: day ?? line, time: time ?? '' }
      })
  : defaultHours

// Split address into lines for display
const addressLines = address ? address.split('\n').map((l) => l.trim()).filter(Boolean) : []
---

<style>
  .flatpickr-calendar {
    font-family: Georgia, serif;
    border: 1px solid #E8E0D0;
    border-radius: 4px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    background: #FAFAF7;
  }
  .flatpickr-months {
    background: #2C2C2C;
    border-radius: 4px 4px 0 0;
    padding: 8px 0;
  }
  .flatpickr-month, .flatpickr-prev-month, .flatpickr-next-month {
    color: #FAFAF7 !important;
    fill: #FAFAF7 !important;
  }
  .flatpickr-current-month .flatpickr-monthDropdown-months,
  .flatpickr-current-month input.cur-year {
    color: #FAFAF7;
    font-size: 15px;
  }
  .flatpickr-weekday {
    color: #C9A96E;
    font-weight: 600;
    font-size: 12px;
  }
  .flatpickr-day {
    color: #2C2C2C;
    border-radius: 2px;
  }
  .flatpickr-day:hover {
    background: #F5F0E8;
    border-color: #C9A96E;
  }
  .flatpickr-day.selected,
  .flatpickr-day.selected:hover {
    background: #C9A96E;
    border-color: #C9A96E;
    color: #fff;
  }
  .flatpickr-day.today {
    border-color: #C9A96E;
    color: #C9A96E;
    font-weight: bold;
  }
  .flatpickr-day.today.selected {
    color: #fff;
  }
  .flatpickr-day.flatpickr-disabled {
    color: #D0C9BE;
  }
</style>

<section id="contacto" class="py-16 md:py-24 bg-[#F5F0E8]">
  <div class="max-w-7xl mx-auto px-4 md:px-6 grid md:grid-cols-2 gap-10 md:gap-16">
    <!-- Info -->
    <div>
      <p class="text-[#C9A96E] text-sm font-medium tracking-widest uppercase mb-3">
        {subtitle}
      </p>
      <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-[#2C2C2C] mb-8 reveal">
        {title}
      </h2>

      <div class="space-y-6 mb-10">
        {addressLines.length > 0 && (
          <div>
            <p class="text-xs text-[#6B6B6B] uppercase tracking-wider mb-1">Dirección</p>
            {addressLines.map((line, i) => (
              i === 0
                ? <p class="text-[#2C2C2C] font-medium">{line}</p>
                : <p class="text-[#6B6B6B] text-sm">{line}</p>
            ))}
          </div>
        )}
        {phone && (
          <div>
            <p class="text-xs text-[#6B6B6B] uppercase tracking-wider mb-1">Teléfono</p>
            <a href={`tel:${phone.replace(/[\s()\-]/g, '')}`} class="text-[#2C2C2C] font-medium hover:text-[#C9A96E] transition-colors">
              {phone}
            </a>
          </div>
        )}
        {email && (
          <div>
            <p class="text-xs text-[#6B6B6B] uppercase tracking-wider mb-1">Correo</p>
            <a href={`mailto:${email}`} class="text-[#2C2C2C] font-medium hover:text-[#C9A96E] transition-colors">
              {email}
            </a>
          </div>
        )}
      </div>

      <div>
        <p class="text-xs text-[#6B6B6B] uppercase tracking-wider mb-3">Horarios</p>
        <div class="space-y-2">
          {hours.map((h) => (
            <div class="flex justify-between border-b border-[#E8E0D0] pb-2">
              <span class="text-sm text-[#2C2C2C]">{h.day}</span>
              <span class="text-sm text-[#6B6B6B]">{h.time}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Form -->
    <div class="bg-white p-6 md:p-10 border border-[#E8E0D0] rounded-sm shadow-sm reveal reveal-delay-1">
      <h3 class="font-serif text-2xl font-bold text-[#2C2C2C] mb-6">Haz tu reservación</h3>
      <div id="form-success" class="hidden text-center py-8">
        <p class="text-2xl mb-2">✓</p>
        <p class="font-serif text-xl text-[#2C2C2C] mb-1">¡Reservación recibida!</p>
        <p class="text-sm text-[#6B6B6B]">Te confirmaremos por correo a la brevedad.</p>
      </div>
      <form id="contact-form" class="space-y-5" novalidate>
        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label for="nombre" class="block text-xs text-[#6B6B6B] uppercase tracking-wider mb-1.5">Nombre</label>
            <input
              type="text"
              id="nombre"
              name="nombre"
              placeholder="Tu nombre"
              required
              class="w-full px-4 py-2.5 border border-[#E8E0D0] rounded text-sm text-[#2C2C2C] bg-[#FAFAF7] focus:outline-none focus:border-[#C9A96E] transition-colors"
            />
          </div>
          <div>
            <label for="email" class="block text-xs text-[#6B6B6B] uppercase tracking-wider mb-1.5">Correo</label>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="tu@correo.com"
              required
              class="w-full px-4 py-2.5 border border-[#E8E0D0] rounded text-sm text-[#2C2C2C] bg-[#FAFAF7] focus:outline-none focus:border-[#C9A96E] transition-colors"
            />
          </div>
        </div>
        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label for="fecha" class="block text-xs text-[#6B6B6B] uppercase tracking-wider mb-1.5">Fecha</label>
            <input
              type="text"
              id="fecha"
              name="fecha"
              placeholder="Seleccioná una fecha"
              required
              readonly
              class="w-full px-4 py-2.5 border border-[#E8E0D0] rounded text-sm text-[#2C2C2C] bg-[#FAFAF7] focus:outline-none focus:border-[#C9A96E] transition-colors cursor-pointer"
            />
          </div>
          <div>
            <label for="personas" class="block text-xs text-[#6B6B6B] uppercase tracking-wider mb-1.5">Personas</label>
            <select
              id="personas"
              name="personas"
              class="w-full px-4 py-2.5 border border-[#E8E0D0] rounded text-sm text-[#2C2C2C] bg-[#FAFAF7] focus:outline-none focus:border-[#C9A96E] transition-colors"
            >
              {[1,2,3,4,5,6,7,8].map((n) => (
                <option value={n}>{n} {n === 1 ? 'persona' : 'personas'}</option>
              ))}
              <option value="9+">9 o más</option>
            </select>
          </div>
        </div>
        <div>
          <label for="mensaje" class="block text-xs text-[#6B6B6B] uppercase tracking-wider mb-1.5">Mensaje especial (opcional)</label>
          <textarea
            id="mensaje"
            name="mensaje"
            rows="3"
            placeholder="Alergias, ocasión especial, preferencias de mesa..."
            class="w-full px-4 py-2.5 border border-[#E8E0D0] rounded text-sm text-[#2C2C2C] bg-[#FAFAF7] focus:outline-none focus:border-[#C9A96E] transition-colors resize-none"
          ></textarea>
        </div>
        <p id="form-error" class="hidden text-sm text-red-600"></p>
        <button
          id="submit-btn"
          type="submit"
          class="w-full py-3 bg-[#C9A96E] text-white font-medium rounded hover:bg-[#A8834A] transition-colors duration-200 disabled:opacity-60 disabled:cursor-not-allowed"
        >
          {reservationCtaText}
        </button>
      </form>
    </div>
  </div>
</section>

<script>
  import flatpickr from 'flatpickr'
  import 'flatpickr/dist/flatpickr.min.css'
  import { Spanish } from 'flatpickr/dist/l10n/es'

  flatpickr('#fecha', {
    locale: Spanish,
    minDate: 'today',
    dateFormat: 'd/m/Y',
    disableMobile: true,
    onReady(_selectedDates, _dateStr, instance) {
      const cal = instance.calendarContainer
      cal.style.setProperty('--fp-accent', '#C9A96E')
      cal.style.fontFamily = 'Georgia, serif'
    },
  })

  const form = document.getElementById('contact-form') as HTMLFormElement
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement
  const errorEl = document.getElementById('form-error') as HTMLParagraphElement
  const successEl = document.getElementById('form-success') as HTMLDivElement

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    errorEl.classList.add('hidden')
    submitBtn.disabled = true
    submitBtn.textContent = 'Enviando...'

    const res = await fetch('/api/contact', {
      method: 'POST',
      body: new FormData(form),
    })

    const json = await res.json()

    if (res.ok) {
      form.classList.add('hidden')
      successEl.classList.remove('hidden')
    } else {
      errorEl.textContent = json.error ?? 'Error al enviar. Intentá de nuevo.'
      errorEl.classList.remove('hidden')
      submitBtn.disabled = false
      submitBtn.textContent = 'Confirmar reservación'
    }
  })
</script>
