---
import { getFeaturedTours, urlFor } from '../lib/sanity'
import { useTranslations } from '../i18n/index'
import type { Locale } from '../i18n/index'

interface Props {
  lang?: Locale;
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);

const featuredTours = await getFeaturedTours(lang)

const difficultyColors: Record<string, string> = {
  facil: 'bg-green-500',
  moderado: 'bg-yellow-500',
  dificil: 'bg-orange-500',
  'muy-dificil': 'bg-red-500',
}
---

<section id="tours" class="py-16 md:py-24" style="background-color: var(--color-bg)">
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    <!-- Header -->
    <div class="text-center mb-16">
      <p class="text-sm font-medium tracking-widest uppercase mb-3" style="color: var(--color-accent)">
        {t.tours.featuredLabel}
      </p>
      <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold mb-4 reveal" style="color: var(--color-text)">
        {t.tours.featuredTitle}
      </h2>
      <p class="max-w-lg mx-auto" style="color: var(--color-muted)">
        {t.tours.featuredSubtitle}
      </p>
    </div>

    <!-- Empty state -->
    {featuredTours.length === 0 && (
      <p class="text-center py-8" style="color: var(--color-muted)">
        {t.tours.featuredEmpty}
      </p>
    )}

    <!-- Cards grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {featuredTours.map((tour, i) => (
        <article
          class={`rounded-lg overflow-hidden group hover:shadow-lg transition-shadow duration-300 reveal${i === 1 ? ' reveal-delay-1' : i === 2 ? ' reveal-delay-2' : ''}`}
          style="background-color: white; border: 1px solid var(--color-border)"
        >
          <!-- Image -->
          <div class="relative h-48 overflow-hidden">
            <img
              src={urlFor(tour.image).width(600).height(192).format('webp').quality(85).url()}
              alt={tour.altText ?? tour.name}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            <!-- Difficulty badge -->
            {tour.difficulty && (
              <span
                class={`absolute top-3 right-3 ${difficultyColors[tour.difficulty] ?? 'bg-gray-500'} text-white text-xs font-semibold px-2 py-1 rounded`}
              >
                {t.tours.difficulty[tour.difficulty] ?? tour.difficulty}
              </span>
            )}
          </div>

          <!-- Card body -->
          <div class="p-5">
            <h3 class="font-serif text-lg font-bold mb-2" style="color: var(--color-text)">{tour.name}</h3>
            {tour.shortDescription && (
              <p
                class="text-sm leading-relaxed mb-4 line-clamp-2"
                style="color: var(--color-muted)"
              >
                {tour.shortDescription}
              </p>
            )}

            <!-- Meta row -->
            <div class="flex items-center justify-between mb-4 text-sm" style="color: var(--color-muted)">
              <span>⏱ {tour.duration}</span>
              <span class="font-bold text-base" style="color: var(--color-accent)">
                {t.tours.fromPrice} {tour.price}
              </span>
            </div>

            <!-- CTA -->
            <a
              href={`/${lang}/tours/${tour.slug.current}`}
              class="block w-full text-center px-4 py-2.5 rounded text-sm font-medium transition-colors duration-200"
              style="background-color: var(--color-primary); color: white;"
              onmouseover="this.style.backgroundColor='var(--color-primary-dark)'"
              onmouseout="this.style.backgroundColor='var(--color-primary)'"
            >
              {t.tours.viewTour}
            </a>
          </div>
        </article>
      ))}
    </div>

    {featuredTours.length > 0 && (
      <div class="text-center mt-12">
        <a
          href={`/${lang}/tours`}
          class="inline-block px-8 py-3 text-sm font-medium rounded transition-colors duration-200"
          style="border: 1px solid var(--color-primary); color: var(--color-primary);"
          onmouseover="this.style.backgroundColor='var(--color-primary)'; this.style.color='white'"
          onmouseout="this.style.backgroundColor='transparent'; this.style.color='var(--color-primary)'"
        >
          {t.tours.viewAll}
        </a>
      </div>
    )}
  </div>
</section>
