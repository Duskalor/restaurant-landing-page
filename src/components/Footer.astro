---
import { personal, footer } from '../data/portfolio';

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-white/10 py-8">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center">
      <p class="text-slate-400 mb-2">
        &copy; {currentYear} {personal.name}. Built with <span class="text-emerald-400 animate-pulse">&hearts;</span> using
        <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="text-emerald-400 font-semibold hover:opacity-80 transition-opacity">
          Astro
        </a>
      </p>
      <p class="text-slate-500 text-sm">
        {footer.tagline}
      </p>
    </div>
  </div>
</footer>
