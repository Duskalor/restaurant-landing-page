---
// T-15: Footer
// TODO: replace placeholder logo text with <Image /> when client provides logo asset

const practiceAreas = [
  "Defensa en Juicio Oral",
  "Delitos Económicos y Financieros",
  "Narcotráfico y Crimen Organizado",
  "Violencia Doméstica",
  "Delitos Informáticos",
  "Recursos de Apelación",
  "Medidas Cautelares",
  "Excarcelaciones",
];
---

<footer class="bg-navy border-t border-white/10">
  <div class="max-w-6xl mx-auto px-6 py-16">

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">

      <!-- Col 1: Logo + contacto -->
      <div class="flex flex-col gap-5">
        <!-- Logo SVG -->
        <img src="/logo.svg" alt="CRC Abogados Asociados" class="h-16 w-auto" />

        <p class="font-sans text-white/50 text-sm leading-relaxed">
          Estudio jurídico especializado en derecho penal. Más de 15 años defendiendo la libertad y los derechos de nuestros clientes.
        </p>

        <div class="flex flex-col gap-3 text-sm">
          <!-- Phone -->
          <a href="tel:+51840000000" class="flex items-center gap-2 text-white/70 hover:text-gold transition-colors duration-200 font-sans">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
            </svg>
            <!-- TODO: replace with real phone number -->
            +51 84 000-0000
          </a>

          <!-- Email -->
          <a href="mailto:contacto@crcabogados.com.ar" class="flex items-center gap-2 text-white/70 hover:text-gold transition-colors duration-200 font-sans">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
            </svg>
            <!-- TODO: replace with real email -->
            contacto@crcabogados.com.ar
          </a>

          <!-- Address -->
          <div class="flex items-start gap-2 text-white/70 font-sans">
            <svg class="w-4 h-4 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
            </svg>
            <!-- TODO: replace with real address -->
            <span>Av. Ejemplo 123, Piso 5<br />Cusco, Perú</span>
          </div>
        </div>

        <!-- LinkedIn -->
        <a
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-white/50 hover:text-gold transition-colors duration-200 font-sans text-sm"
          aria-label="LinkedIn de CRC Abogados Asociados"
        >
          <!-- TODO: replace href with real LinkedIn URL -->
          <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
      </div>

      <!-- Col 2: Áreas de práctica -->
      <div>
        <h3 class="font-serif text-white text-base font-semibold mb-5">Áreas de Práctica</h3>
        <ul class="flex flex-col gap-2">
          {practiceAreas.map((area) => (
            <li>
              <a href="#contacto" class="font-sans text-white/60 text-sm hover:text-gold transition-colors duration-200">
                {area}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Links legales -->
      <div>
        <h3 class="font-serif text-white text-base font-semibold mb-5">Información</h3>
        <ul class="flex flex-col gap-2 mb-8">
          <li>
            <a href="#" class="font-sans text-white/60 text-sm hover:text-gold transition-colors duration-200">
              <!-- TODO: create and link real privacy policy page -->
              Política de privacidad
            </a>
          </li>
          <li>
            <a href="#" class="font-sans text-white/60 text-sm hover:text-gold transition-colors duration-200">
              <!-- TODO: create and link real terms page -->
              Términos y condiciones
            </a>
          </li>
          <li>
            <a href="#contacto" class="font-sans text-white/60 text-sm hover:text-gold transition-colors duration-200">
              Contacto
            </a>
          </li>
        </ul>

        <!-- WhatsApp CTA -->
        <a
          href="https://wa.me/51840000000?text=Hola%2C%20necesito%20asesoramiento%20legal"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-[#25D366] text-white font-sans font-semibold text-sm px-5 py-3 rounded-sm hover:bg-[#20b857] transition-colors duration-200"
        >
          <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Emergencias 24/7
        </a>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="max-w-6xl mx-auto px-6 py-5 flex flex-col md:flex-row items-center justify-between gap-3">
      <p class="font-sans text-white/40 text-xs text-center md:text-left">
        © 2026 CRC Abogados Asociados. Todos los derechos reservados.
      </p>
      <p class="font-sans text-white/30 text-xs text-center md:text-right max-w-md leading-relaxed">
        Los resultados pasados no garantizan resultados futuros. Cada caso es único y depende de sus circunstancias particulares.
      </p>
    </div>
  </div>
</footer>
