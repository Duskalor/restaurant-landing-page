---
import { getSiteSettings } from '../lib/sanity'

const settings = await getSiteSettings()

const businessName = settings?.businessName ?? 'Restaurante'
const phone = settings?.phone ?? null
const email = settings?.email ?? null
const address = settings?.address ?? null
const instagram = settings?.instagram ?? null
const facebook = settings?.facebook ?? null

const links = [
  { label: 'Nosotros', href: '/nosotros' },
  { label: 'Menú', href: '/menu' },
  { label: 'Galería', href: '/galeria' },
  { label: 'Reseñas', href: '/resenas' },
  { label: 'Contacto', href: '/contacto' },
]

const year = new Date().getFullYear()
---

<footer class="bg-[#2C2C2C] text-white py-16">
  <div class="max-w-7xl mx-auto px-4 md:px-6 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8 md:gap-10">
    <!-- Brand -->
    <div class="md:col-span-2">
      <p class="font-serif text-3xl font-bold text-[#C9A96E] mb-3">{businessName}</p>
      <p class="text-white/60 text-sm leading-relaxed max-w-sm">
        {address ?? 'Una experiencia gastronómica que celebra los sabores y la hospitalidad de nuestra tierra.'}
      </p>
    </div>

    <!-- Nav -->
    <div>
      <p class="text-xs text-white/40 uppercase tracking-widest mb-4">Navegación</p>
      <ul class="space-y-2">
        {links.map((link) => (
          <li>
            <a href={link.href} class="text-sm text-white/70 hover:text-[#C9A96E] transition-colors">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Contact & Socials -->
    <div>
      <p class="text-xs text-white/40 uppercase tracking-widest mb-4">Contacto</p>
      {phone && (
        <a href={`tel:${phone.replace(/[\s()\-]/g, '')}`} class="block text-sm text-white/70 hover:text-[#C9A96E] transition-colors mb-1">
          {phone}
        </a>
      )}
      {email && (
        <a href={`mailto:${email}`} class="block text-sm text-white/70 hover:text-[#C9A96E] transition-colors mb-6">
          {email}
        </a>
      )}
      {!phone && !email && (
        <p class="text-sm text-white/40 mb-6">Configurá el contacto en Sanity Studio.</p>
      )}

      {(instagram || facebook) && (
        <>
          <p class="text-xs text-white/40 uppercase tracking-widest mb-3">Síguenos</p>
          <div class="flex gap-3">
            {instagram && (
              <a
                href={instagram}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Instagram"
                class="w-9 h-9 flex items-center justify-center border border-white/20 text-xs text-white/60 hover:border-[#C9A96E] hover:text-[#C9A96E] transition-colors rounded"
              >
                IG
              </a>
            )}
            {facebook && (
              <a
                href={facebook}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Facebook"
                class="w-9 h-9 flex items-center justify-center border border-white/20 text-xs text-white/60 hover:border-[#C9A96E] hover:text-[#C9A96E] transition-colors rounded"
              >
                FB
              </a>
            )}
          </div>
        </>
      )}
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 md:px-6 mt-12 pt-6 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-3">
    <p class="text-xs text-white/40">© {year} {businessName}. Todos los derechos reservados.</p>
    <p class="text-xs text-white/40">Desarrollado con ♥</p>
  </div>
</footer>
