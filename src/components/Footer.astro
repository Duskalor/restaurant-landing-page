---
const socials = [
  { label: 'Instagram', href: '#', icon: 'IG' },
  { label: 'Facebook', href: '#', icon: 'FB' },
  { label: 'TripAdvisor', href: '#', icon: 'TA' },
];

const links = [
  { label: 'Nosotros', href: '#nosotros' },
  { label: 'Menú', href: '#menu' },
  { label: 'Galería', href: '#galeria' },
  { label: 'Reseñas', href: '#resenas' },
  { label: 'Contacto', href: '#contacto' },
];
---

<footer class="bg-[#2C2C2C] text-white py-16">
  <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-4 gap-10">
    <!-- Brand -->
    <div class="md:col-span-2">
      <p class="font-serif text-3xl font-bold text-[#C9A96E] mb-3">La Maison</p>
      <p class="text-white/60 text-sm leading-relaxed max-w-sm">
        Una experiencia gastronómica que celebra la tradición francesa con el alma de nuestra tierra. Calle Triunfo 379, Centro Histórico, Cusco.
      </p>
    </div>

    <!-- Nav -->
    <div>
      <p class="text-xs text-white/40 uppercase tracking-widest mb-4">Navegación</p>
      <ul class="space-y-2">
        {links.map((link) => (
          <li>
            <a href={link.href} class="text-sm text-white/70 hover:text-[#C9A96E] transition-colors">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Contact & Socials -->
    <div>
      <p class="text-xs text-white/40 uppercase tracking-widest mb-4">Contacto</p>
      <p class="text-sm text-white/70 mb-1">+51 (01) 445-6789</p>
      <p class="text-sm text-white/70 mb-6">reservas@lamaison.pe</p>

      <p class="text-xs text-white/40 uppercase tracking-widest mb-3">Síguenos</p>
      <div class="flex gap-3">
        {socials.map((s) => (
          <a
            href={s.href}
            aria-label={s.label}
            class="w-9 h-9 flex items-center justify-center border border-white/20 text-xs text-white/60 hover:border-[#C9A96E] hover:text-[#C9A96E] transition-colors rounded"
          >
            {s.icon}
          </a>
        ))}
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-6 mt-12 pt-6 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-3">
    <p class="text-xs text-white/40">© 2026 La Maison. Todos los derechos reservados.</p>
    <p class="text-xs text-white/40">Diseñado con ♥ en Cusco, Perú</p>
  </div>
</footer>
