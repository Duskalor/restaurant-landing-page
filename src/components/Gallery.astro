---
import { getGalleryImages, urlFor } from '../lib/sanity'
import { useTranslations } from '../i18n/index'
import type { Locale } from '../i18n/index'

interface Props {
  lang?: Locale;
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);

const sanityImages = await getGalleryImages(lang)
---

<section id='galeria' class='py-16 md:py-24 bg-[var(--color-surface)]'>
  <div class='max-w-7xl mx-auto px-4 md:px-6'>
    <div class='text-center mb-16'>
      <p
        class='text-[var(--color-primary)] text-sm font-medium tracking-widest uppercase mb-3'
      >
        {t.gallery.label}
      </p>
      <h2 class='font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-[var(--color-text)] mb-4 reveal'>
        {t.gallery.title}
      </h2>
      <p class='text-[var(--color-muted)] max-w-lg mx-auto'>
        {t.gallery.subtitle}
      </p>
    </div>

    {sanityImages.length > 0 ? (
      <div class='grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-3 auto-rows-[180px] md:auto-rows-[200px] reveal reveal-delay-1'>
        {sanityImages.map((img) => (
          <a
            href={urlFor(img.image).width(1920).height(1080).format('webp').quality(90).url()}
            class='glightbox overflow-hidden rounded-sm block group'
            data-gallery='tours-gallery'
            data-type='image'
            data-description={img.description ?? img.alt ?? img.title ?? ''}
          >
            <img
              src={urlFor(img.image).width(600).height(400).format('webp').quality(85).url()}
              alt={img.alt ?? img.title ?? ''}
              class='w-full h-full object-cover hover:scale-105 transition-transform duration-500'
              loading='lazy'
            />
          </a>
        ))}
      </div>
    ) : (
      <div class='text-center py-16'>
        <p class='text-[var(--color-muted)]'>{t.gallery.empty}</p>
      </div>
    )}
  </div>
</section>

<script>
  import GLightbox from 'glightbox'
  import 'glightbox/dist/css/glightbox.min.css'

  GLightbox({
    selector: '.glightbox',
    touchNavigation: true,
    loop: true,
    autoplayVideos: false,
    zoomable: true,
  })
</script>
