---
// Header con logo y navegación
---

<header class="fixed top-0 left-0 right-0 z-40 bg-navy/95 backdrop-blur-md border-b border-white/5">
  <div class="max-w-6xl mx-auto px-6 py-4">
    <div class="flex items-center justify-between">
      
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3">
        <img src="/logo.svg" alt="CRC Abogados Asociados" class="h-12 w-auto" />
      </a>

      <!-- Navigation (desktop) -->
      <nav class="hidden md:flex items-center gap-8">
        <a href="#especialidades" class="font-sans text-white/80 text-sm hover:text-gold transition-colors">Especialidades</a>
        <a href="#equipo" class="font-sans text-white/80 text-sm hover:text-gold transition-colors">Equipo</a>
        <a href="#contacto" class="font-sans text-white/80 text-sm hover:text-gold transition-colors">Contacto</a>
        <a 
          href="#contacto"
          class="px-5 py-2 bg-gold text-navy font-sans font-semibold text-sm rounded-full hover:bg-yellow-400 transition-colors"
        >
          Consulta confidencial
        </a>
      </nav>

      <!-- Mobile menu button -->
      <button 
        id="mobile-menu-btn"
        class="md:hidden p-2 text-white/80 hover:text-gold transition-colors"
        aria-label="Abrir menú"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>

    </div>
  </div>

  <!-- Mobile menu (hidden by default) -->
  <div id="mobile-menu" class="hidden md:hidden bg-navy/98 border-t border-white/5">
    <div class="px-6 py-4 flex flex-col gap-4">
      <a href="#especialidades" class="font-sans text-white/80 text-base py-2 hover:text-gold transition-colors">Especialidades</a>
      <a href="#equipo" class="font-sans text-white/80 text-base py-2 hover:text-gold transition-colors">Equipo</a>
      <a href="#contacto" class="font-sans text-white/80 text-base py-2 hover:text-gold transition-colors">Contacto</a>
      <a 
        href="#contacto"
        class="px-5 py-3 bg-gold text-navy font-sans font-semibold text-base rounded-full text-center hover:bg-yellow-400 transition-colors"
      >
        Consulta confidencial
      </a>
    </div>
  </div>
</header>

<!-- Spacer para evitar que el contenido quede debajo del header fixed -->
<div class="h-20"></div>

<script>
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  
  mobileBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  // Close menu when clicking on a link
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
    });
  });
</script>