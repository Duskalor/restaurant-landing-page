---
import { navItems, personal } from '../data/portfolio';
---

<header
  class='fixed top-0 left-0 right-0 z-50 bg-black/30 backdrop-blur-md border-b border-white/[0.06]'
>
  <div class='max-w-7xl mx-auto px-6'>
    <nav class='flex justify-between items-center py-4'>
      <a href='/' class='group'>
        <span class='text-2xl font-bold text-emerald-400'>
          &lt;{personal.name.split(' ')[0]} /&gt;
        </span>
      </a>

      <!-- Desktop nav -->
      <ul class='hidden md:flex gap-8 list-none'>
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class='text-slate-400 font-medium hover:text-emerald-400 transition-colors duration-300'
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>

      <!-- Mobile hamburger button -->
      <button
        id='menu-toggle'
        class='md:hidden flex flex-col gap-1.5 p-2 -mr-2'
        aria-label='Toggle menu'
        aria-expanded='false'
      >
        <span class='hamburger-line block w-6 h-0.5 bg-slate-300 transition-all duration-300'></span>
        <span class='hamburger-line block w-6 h-0.5 bg-slate-300 transition-all duration-300'></span>
        <span class='hamburger-line block w-6 h-0.5 bg-slate-300 transition-all duration-300'></span>
      </button>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div
    id='mobile-menu'
    class='md:hidden hidden border-t border-white/[0.06] bg-black/60 backdrop-blur-md'
  >
    <ul class='flex flex-col list-none px-6 py-4 gap-1'>
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class='mobile-nav-link block py-3 text-slate-300 font-medium hover:text-emerald-400 transition-colors duration-200 border-b border-white/[0.06] last:border-0'
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<style>
  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-100%); }
    to { opacity: 1; transform: translateY(0); }
  }
  header {
    animation: slideDown 0.5s ease-out forwards;
  }

  /* Hamburger → X animation */
  .menu-open .hamburger-line:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }
  .menu-open .hamburger-line:nth-child(2) {
    opacity: 0;
  }
  .menu-open .hamburger-line:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }
</style>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    toggle.classList.toggle('menu-open', !isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  // Close menu on nav link click
  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      toggle?.classList.remove('menu-open');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
