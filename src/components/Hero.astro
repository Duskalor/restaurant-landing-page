---
import { getHeroContent, getSiteSettings, urlFor } from '../lib/sanity'
import { useTranslations } from '../i18n/index'
import type { Locale } from '../i18n/index'

interface Props {
  lang?: Locale;
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);

const hero = await getHeroContent(lang)
const settings = await getSiteSettings()

const backgroundImageUrl = hero?.backgroundImage
  ? urlFor(hero.backgroundImage).width(1920).height(1080).format('webp').url()
  : 'https://images.unsplash.com/photo-1526392060635-9d6019884377?w=1600&q=85'

const title = hero?.title ?? t.hero.defaultTitle
const subtitle = hero?.subtitle ?? t.hero.defaultSubtitle
const ctaText = hero?.ctaText ?? t.hero.defaultCta
const ctaLink = hero?.ctaLink ?? `/${lang}/tours`

const bgAlt = settings?.businessName
  ? `${t.hero.bgAlt} ${settings.businessName}`
  : t.hero.bgAltDefault
---

<section
  id='inicio'
  class='relative min-h-screen flex items-center justify-start overflow-hidden'
>
  <!-- Background image -->
  <div class='absolute inset-0'>
    <img
      src={backgroundImageUrl}
      alt={bgAlt}
      class='w-full h-full object-cover'
      loading='eager'
    />
    <div
      class='absolute inset-0 bg-gradient-to-r from-black/70 via-black/40 to-transparent'
    >
    </div>
  </div>

  <!-- Content -->
  <div class='relative z-10 max-w-7xl mx-auto px-4 md:px-6 py-24 md:py-32'>
    <p
      class='text-sm font-medium tracking-widest uppercase mb-4'
      style='color: var(--color-accent)'
    >
      {settings?.businessName ? `${t.hero.welcome} ${settings.businessName}` : t.hero.welcomeDefault}
    </p>
    <h1
      class='font-serif text-white text-3xl md:text-5xl lg:text-7xl font-bold leading-tight max-w-2xl mb-6'
    >
      {title}
    </h1>
    <p class='text-white/80 text-base md:text-lg lg:text-xl max-w-lg mb-10 leading-relaxed'>
      {subtitle}
    </p>
    <div class='flex flex-col sm:flex-row gap-4'>
      <a
        href={ctaLink}
        class='inline-block px-8 py-3.5 text-white font-medium text-base rounded transition-colors duration-200 text-center'
        style='background-color: var(--color-accent)'
        onmouseover="this.style.opacity='0.9'"
        onmouseout="this.style.opacity='1'"
      >
        {ctaText}
      </a>
      <a
        href='#destinos'
        class='inline-block px-8 py-3.5 border border-white/60 text-white font-medium text-base rounded hover:bg-white/10 transition-colors duration-200 text-center'
      >
        {t.hero.ctaDestinations}
      </a>
    </div>
  </div>
</section>
