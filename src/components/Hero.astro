---
import { getHeroContent, getSiteSettings, urlFor } from '../lib/sanity'

const hero = await getHeroContent()
const settings = await getSiteSettings()

const backgroundImageUrl = hero?.backgroundImage
  ? urlFor(hero.backgroundImage).width(1920).height(1080).format('webp').url()
  : 'https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=1600&q=85'

const title = hero?.title ?? 'Una experiencia gastronómica inigualable'
const subtitle = hero?.subtitle ?? 'Sabores que cuentan historias. Ingredientes de temporada, técnica francesa y el calor de nuestra hospitalidad.'
const ctaText = hero?.ctaText ?? 'Reservar una mesa'
const ctaLink = hero?.ctaLink ?? '#contacto'
---

<section
  id='inicio'
  class='relative min-h-screen flex items-center justify-start overflow-hidden'
>
  <!-- Background image -->
  <div class='absolute inset-0'>
    <img
      src={backgroundImageUrl}
      alt={settings?.restaurantName ? `Interior del restaurante ${settings.restaurantName}` : 'Interior del restaurante'}
      class='w-full h-full object-cover'
      loading='eager'
    />
    <div
      class='absolute inset-0 bg-gradient-to-r from-black/70 via-black/40 to-transparent'
    >
    </div>
  </div>

  <!-- Content -->
  <div class='relative z-10 max-w-7xl mx-auto px-4 md:px-6 py-24 md:py-32'>
    <p
      class='text-[#C9A96E] text-sm font-medium tracking-widest uppercase mb-4'
    >
      {settings?.restaurantName ? `Bienvenido a ${settings.restaurantName}` : 'Bienvenido'}
    </p>
    <h1
      class='font-serif text-white text-3xl md:text-5xl lg:text-7xl font-bold leading-tight max-w-2xl mb-6'
    >
      {title}
    </h1>
    <p class='text-white/80 text-base md:text-lg lg:text-xl max-w-lg mb-10 leading-relaxed'>
      {subtitle}
    </p>
    <div class='flex flex-col sm:flex-row gap-4'>
      <a
        href={ctaLink}
        class='inline-block px-8 py-3.5 bg-[#C9A96E] text-white font-medium text-base rounded hover:bg-[#A8834A] transition-colors duration-200 text-center'
      >
        {ctaText}
      </a>
      <a
        href='#menu'
        class='inline-block px-8 py-3.5 border border-white/60 text-white font-medium text-base rounded hover:bg-white/10 transition-colors duration-200 text-center'
      >
        Ver el menú
      </a>
    </div>
  </div>
</section>
