---
import { personal } from '../data/portfolio';
---

<section
  id='hero'
  class='min-h-screen flex items-center pt-20 relative overflow-hidden mesh-bg'
>
  <div class='max-w-7xl mx-auto px-6 w-full'>
    <div class='grid md:grid-cols-2 gap-12 md:gap-16 items-center'>
      <!-- Left: Display copy -->
      <div data-animate data-delay='0'>
        <div class='flex items-center gap-4 mb-6'>
          <div
            class='w-16 h-16 rounded-full bg-emerald-500/20 ring-2 ring-emerald-500/60 ring-offset-2 ring-offset-transparent flex items-center justify-center shrink-0'
          >
            <span class='text-2xl font-black text-emerald-400'>
              {personal.name.charAt(0)}
            </span>
          </div>
          <p
            class='text-emerald-400 font-semibold tracking-widest uppercase text-xs'
          >
            {personal.role}
          </p>
        </div>
        <h1
          class='text-5xl md:text-7xl lg:text-8xl font-black leading-none tracking-tight mb-6 text-white'
        >
          {personal.name.split(' ')[0]}
          <span class='text-emerald-400'>{personal.name.split(' ')[1]}</span>
        </h1>
        <p class='text-xl text-slate-400 mb-10 leading-relaxed max-w-md'>
          {personal.tagline}
        </p>
        <div class='flex gap-4 flex-wrap'>
          <a
            href='#projects'
            class='px-7 py-3.5 rounded-lg font-semibold bg-emerald-500 text-zinc-950 hover:-translate-y-0.5 hover:bg-emerald-400 hover:shadow-lg hover:shadow-emerald-500/30 transition-all duration-200'
          >
            View Projects
          </a>
          <a
            href='#contact'
            class='px-7 py-3.5 rounded-lg font-semibold border border-white/20 text-slate-300 hover:border-emerald-400 hover:text-emerald-400 transition-all duration-200'
          >
            Contact Me
          </a>
        </div>
      </div>

      <!-- Right: Terminal -->
      <div data-animate data-delay='200' class='hidden md:block'>
        <div
          class='rounded-2xl overflow-hidden border border-white/10 bg-slate-950/80 backdrop-blur-xl shadow-2xl'
        >
          <!-- Terminal header bar -->
          <div
            class='flex items-center gap-2 px-4 py-3 bg-emerald-950/90 border-b border-white/10'
          >
            <span class='w-3 h-3 rounded-full bg-red-500/70'></span>
            <span class='w-3 h-3 rounded-full bg-yellow-500/70'></span>
            <span class='w-3 h-3 rounded-full bg-green-500/70'></span>
            <span class='ml-3 text-xs text-slate-500 font-mono'
              >~/portfolio</span
            >
          </div>
          <!-- Terminal body -->
          <div
            class='p-6 font-mono text-sm leading-loose min-h-48'
            id='terminal-body'
          >
            <span class='text-slate-500'><!-- lines injected by JS --></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const lines = [
    { prompt: true, text: 'whoami' },
    { prompt: false, text: 'Your Name — Your Role 🚀', delay: 400 },
    { prompt: true, text: 'cat skills.txt', delay: 700 },
    {
      prompt: false,
      text: 'TypeScript · React · Node.js · Astro',
      delay: 1100,
    },
    { prompt: true, text: 'ls projects/', delay: 1500 },
    { prompt: false, text: 'Your projects. Check below ↓', delay: 1900 },
    { prompt: true, text: '_', delay: 2400, cursor: true },
  ];

  const terminal = document.getElementById('terminal-body');
  if (terminal) {
    terminal.innerHTML = '';
    const accentColor =
      getComputedStyle(document.documentElement)
        .getPropertyValue('--color-accent')
        .trim() || '#22c55e';

    lines.forEach((line, i) => {
      setTimeout(
        () => {
          const el = document.createElement('div');
          if (line.cursor) {
            el.innerHTML = `<span style="color:${accentColor}">$ </span><span class="animate-pulse">▋</span>`;
          } else if (line.prompt) {
            el.innerHTML = `<span style="color:${accentColor}">$ </span><span style="color:#f8fafc">${line.text}</span>`;
          } else {
            el.innerHTML = `<span style="color:#94a3b8">> </span><span style="color:#cbd5e1">${line.text}</span>`;
          }
          terminal.appendChild(el);
        },
        line.delay || i * 300,
      );
    });
  }
</script>
