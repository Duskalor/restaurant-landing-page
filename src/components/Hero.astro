---
// T-06: Hero Section — Modernizado con imagen de fondo profesional y efectos premium
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Background Image with overlay -->
  <div class="absolute inset-0">
    <img
      src="https://images.pexels.com/photos/14212986/pexels-photo-14212986.jpeg?auto=compress&cs=tinysrgb&w=1920&q=80"
      alt="CRC Abogados Asociados - Palacio de justicia"
      class="w-full h-full object-cover object-center"
      loading="eager"
    />
    <!-- Dark gradient overlay for text readability -->
    <div class="absolute inset-0 bg-gradient-to-b from-navy/90 via-navy/85 to-navy/95"></div>
  </div>

  <!-- Modern mesh gradient accent con parallax -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <div class="absolute top-0 right-0 w-[600px] h-[600px] rounded-full bg-gold/5 blur-[120px] -translate-y-1/2 translate-x-1/3"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] rounded-full bg-gold/3 blur-[100px] translate-y-1/3 -translate-x-1/4"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-4xl mx-auto px-6 py-32 text-center">
    <!-- Modern badge with glow -->
    <div class="inline-flex items-center justify-center mb-8">
      <span class="relative px-6 py-2.5 bg-navy/60 backdrop-blur-md border border-gold/30 rounded-full">
        <span class="absolute inset-0 rounded-full bg-gold/10 animate-pulse"></span>
        <span class="relative font-sans font-medium text-xs tracking-[0.2em] uppercase text-gold">
          Estudio Jurídico Penal
        </span>
      </span>
    </div>

    <!-- H1 con fluid typography -->
    <h1 class="font-serif text-white text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6 tracking-tight text-fluid">
      Defendemos tu <span class="text-gradient-gold">libertad</span><br class="hidden md:block" />
      con integridad y experiencia
    </h1>

    <!-- Subheadline -->
    <p class="font-sans text-white/70 text-lg md:text-xl max-w-2xl mx-auto mb-12 leading-relaxed">
      Más de 15 años defendiendo derechos en Cusco. Tu libertad es nuestra prioridad.
    </p>

    <!-- CTAs with modern styling -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-5">
      <!-- Primary CTA con shimmer -->
      <a
        href="#contacto"
        class="group relative px-8 py-4 bg-gold text-navy font-sans font-semibold text-base rounded-full overflow-hidden transition-all duration-300 hover:shadow-[0_0_30px_rgba(201,168,76,0.4)] btn-shimmer"
      >
        <span class="relative z-10 flex items-center gap-2">
          Solicitar consulta gratuita
          <svg class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
          </svg>
        </span>
        <!-- Hover glow effect -->
        <span class="absolute inset-0 bg-gradient-to-r from-yellow-400 to-gold opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
      </a>

      <!-- Secondary CTA -->
      <a
        href="https://wa.me/51840000000"
        target="_blank"
        rel="noopener noreferrer"
        class="group px-8 py-4 bg-white/10 backdrop-blur-sm border border-white/20 text-white font-sans font-medium text-base rounded-full hover:bg-white/20 hover:border-white/40 transition-all duration-300 flex items-center gap-3"
      >
        <svg class="w-5 h-5 fill-[#25D366]" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        <span>Emergencias 24/7</span>
      </a>
    </div>

    <!-- Trust indicators -->
    <div class="mt-16 flex flex-wrap items-center justify-center gap-8 text-white/50 text-sm font-sans">
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-gold" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.388-4.005 9.377-9 9.377-4.995 0-9-3.99-9-9.377 0-.681.056-1.351.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
        </svg>
        <span>Secreto profesional garantizado</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <span>Respuesta en menos de 2 horas</span>
      </div>
    </div>
  </div>

  <!-- Bottom indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <div class="w-6 h-10 border-2 border-white/30 rounded-full flex justify-center pt-2">
      <div class="w-1.5 h-3 bg-gold rounded-full animate-pulse"></div>
    </div>
  </div>
</section>