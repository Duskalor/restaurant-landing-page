---
import type { Locale } from '../i18n/index'
import { SUPPORTED_LOCALES } from '../i18n/index'
import 'flag-icons/css/flag-icons.min.css'

interface Props {
  lang: Locale
  currentPath: string
}

const { lang, currentPath } = Astro.props

const flagCodes: Record<Locale, string> = {
  es: 'es',
  en: 'us',
  pt: 'br',
}

const displayLabels: Record<Locale, string> = {
  es: 'ES',
  en: 'EN',
  pt: 'PR',
}

function getLocalePath(targetLang: Locale): string {
  const segments = currentPath.split('/').filter(Boolean)
  if (SUPPORTED_LOCALES.includes(segments[0] as Locale)) {
    segments[0] = targetLang
  } else {
    segments.unshift(targetLang)
  }
  return '/' + segments.join('/')
}
---

<div class="relative group">
  <button
    class="flex items-center gap-1.5 text-sm font-medium px-3 py-1.5 rounded-lg transition-colors duration-200"
    style="color: var(--color-text); border: 1px solid var(--color-border);"
    aria-label="Change language"
  >
    <span class={`fi fi-${flagCodes[lang]} fis`} style="width:24px; height:24px; border-radius:50%;"></span>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <polyline points="6 9 12 15 18 9"/>
    </svg>
  </button>

  <div
    class="absolute right-0 top-full mt-1 py-1 rounded-lg shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 min-w-[90px]"
    style="background-color: white; border: 1px solid var(--color-border);"
  >
    {SUPPORTED_LOCALES.map((locale) => (
      <a
        href={getLocalePath(locale)}
        class={`flex items-center gap-2 px-3 py-2 transition-colors duration-150 ${locale === lang ? 'opacity-100' : 'opacity-60 hover:opacity-100'}`}
        style={locale === lang ? 'background-color: var(--color-surface);' : ''}
        onmouseover={locale !== lang ? "this.style.backgroundColor='var(--color-surface)'" : undefined}
        onmouseout={locale !== lang ? "this.style.backgroundColor='transparent'" : undefined}
      >
        <span class={`fi fi-${flagCodes[locale]} fis`} style="width:24px; height:24px; border-radius:50%;"></span>
        <span class="text-xs font-medium">{displayLabels[locale]}</span>
      </a>
    ))}
  </div>
</div>
