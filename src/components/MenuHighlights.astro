---
import { getFeaturedMenuItems, urlFor } from '../lib/sanity';

const categoryLabels: Record<string, string> = {
  entrada: 'Entrada',
  principal: 'Plato principal',
  postre: 'Postre',
  bebida: 'Bebida',
};

const featuredItems = await getFeaturedMenuItems();
---

<section id="menu" class="py-16 md:py-24 bg-[#FAFAF7]">
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    <!-- Header -->
    <div class="text-center mb-16">
      <p class="text-[#C9A96E] text-sm font-medium tracking-widest uppercase mb-3">
        Lo mejor de nuestra cocina
      </p>
      <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-[#2C2C2C] mb-4 reveal">
        Especialidades de la casa
      </h2>
      <p class="text-[#6B6B6B] max-w-lg mx-auto">
        Una selección de nuestros platos más celebrados, elaborados con ingredientes de temporada y técnica impecable.
      </p>
    </div>

    <!-- Empty state -->
    {featuredItems.length === 0 && (
      <p class="text-center text-[#6B6B6B] py-8">
        Marcá platos como destacados en Sanity Studio para mostrarlos aquí.
      </p>
    )}

    <!-- Cards grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 md:gap-8">
      {featuredItems.map((item, i) => (
        <article class={`bg-white border border-[#E8E0D0] rounded-sm overflow-hidden group hover:shadow-md transition-shadow duration-300 reveal${i === 1 ? ' reveal-delay-1' : i === 2 ? ' reveal-delay-2' : ''}`}>
          <div class="overflow-hidden h-44 sm:h-52">
            <img
              src={urlFor(item.image).width(400).height(208).format('webp').url()}
              alt={item.imageAlt || item.name}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
          <div class="p-5">
            <span class="text-xs text-[#C9A96E] font-medium uppercase tracking-wider">
              {categoryLabels[item.category]}
            </span>
            <h3 class="font-serif text-lg font-bold text-[#2C2C2C] mt-1 mb-2">{item.name}</h3>
            <p class="text-sm text-[#6B6B6B] leading-relaxed mb-4">{item.description}</p>
            <p class="font-serif text-xl font-bold text-[#C9A96E]">S/. {Number(item.price).toFixed(2)}</p>
          </div>
        </article>
      ))}
    </div>

    <div class="text-center mt-12">
      <a
        href="/menu"
        class="inline-block px-8 py-3 border border-[#C9A96E] text-[#C9A96E] font-medium rounded hover:bg-[#C9A96E] hover:text-white transition-colors duration-200"
      >
        Ver menú completo
      </a>
    </div>
  </div>
</section>
