---
import { featuredItems } from '../data/menu';

const categoryLabels: Record<string, string> = {
  entrada: 'Entrada',
  principal: 'Plato principal',
  postre: 'Postre',
  bebida: 'Bebida',
};
---

<section id="menu" class="py-24 bg-[#FAFAF7]">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Header -->
    <div class="text-center mb-16">
      <p class="text-[#C9A96E] text-sm font-medium tracking-widest uppercase mb-3">
        Lo mejor de nuestra cocina
      </p>
      <h2 class="font-serif text-4xl md:text-5xl font-bold text-[#2C2C2C] mb-4">
        Especialidades de la casa
      </h2>
      <p class="text-[#6B6B6B] max-w-lg mx-auto">
        Una selección de nuestros platos más celebrados, elaborados con ingredientes de temporada y técnica impecable.
      </p>
    </div>

    <!-- Cards grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
      {featuredItems.map((item) => (
        <article class="bg-white border border-[#E8E0D0] rounded-sm overflow-hidden group hover:shadow-md transition-shadow duration-300">
          <div class="overflow-hidden h-52">
            <img
              src={item.image}
              alt={item.name}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
          <div class="p-5">
            <span class="text-xs text-[#C9A96E] font-medium uppercase tracking-wider">
              {categoryLabels[item.category]}
            </span>
            <h3 class="font-serif text-lg font-bold text-[#2C2C2C] mt-1 mb-2">{item.name}</h3>
            <p class="text-sm text-[#6B6B6B] leading-relaxed mb-4">{item.description}</p>
            <p class="font-serif text-xl font-bold text-[#C9A96E]">{item.price}</p>
          </div>
        </article>
      ))}
    </div>

    <div class="text-center mt-12">
      <a
        href="#contacto"
        class="inline-block px-8 py-3 border border-[#C9A96E] text-[#C9A96E] font-medium rounded hover:bg-[#C9A96E] hover:text-white transition-colors duration-200"
      >
        Ver menú completo
      </a>
    </div>
  </div>
</section>
