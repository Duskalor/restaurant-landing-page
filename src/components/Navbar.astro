---
import { getSiteSettings, urlFor } from '../lib/sanity'

const settings = await getSiteSettings()
const restaurantName = settings?.restaurantName ?? 'Restaurante'
const logoUrl = settings?.logo
  ? urlFor(settings.logo).width(160).height(48).format('webp').url()
  : null

const links = [
  { label: 'Nosotros', href: '/nosotros' },
  { label: 'Menú', href: '/menu' },
  { label: 'Galería', href: '/galeria' },
  { label: 'Reseñas', href: '/resenas' },
  { label: 'Contacto', href: '/contacto' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-[#FAFAF7]/95 backdrop-blur-sm border-b border-[#E8E0D0]">
  <nav class="max-w-7xl mx-auto px-4 md:px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="font-serif text-2xl font-bold text-[#2C2C2C] tracking-wide">
      {logoUrl
        ? <img src={logoUrl} alt={restaurantName} class="h-10 w-auto object-contain" />
        : restaurantName
      }
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-8">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-sm font-medium text-[#6B6B6B] hover:text-[#C9A96E] transition-colors duration-200"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA -->
    <a
      href="/contacto"
      class="hidden md:inline-block px-5 py-2 text-sm font-medium bg-[#C9A96E] text-white rounded hover:bg-[#A8834A] transition-colors duration-200"
    >
      Reservar mesa
    </a>

    <!-- Mobile burger -->
    <button
      id="burger"
      aria-label="Abrir menú"
      class="md:hidden flex flex-col gap-1.5 p-2"
    >
      <span class="w-6 h-0.5 bg-[#2C2C2C] block transition-all" id="b1"></span>
      <span class="w-6 h-0.5 bg-[#2C2C2C] block transition-all" id="b2"></span>
      <span class="w-6 h-0.5 bg-[#2C2C2C] block transition-all" id="b3"></span>
    </button>
  </nav>

  <!-- Mobile drawer -->
  <div
    id="mobile-menu"
    class="md:hidden hidden flex-col gap-4 px-4 md:px-6 py-6 bg-[#FAFAF7] border-t border-[#E8E0D0]"
  >
    {links.map((link) => (
      <a
        href={link.href}
        class="text-base font-medium text-[#2C2C2C] hover:text-[#C9A96E] transition-colors"
        data-mobile-link
      >
        {link.label}
      </a>
    ))}
    <a
      href="/contacto"
      class="mt-2 inline-block text-center px-5 py-2 text-sm font-medium bg-[#C9A96E] text-white rounded hover:bg-[#A8834A] transition-colors"
      data-mobile-link
    >
      Reservar mesa
    </a>
  </div>
</header>

<script>
  const burger = document.getElementById('burger');
  const menu = document.getElementById('mobile-menu');

  burger?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden');
    menu?.classList.toggle('flex');
  });

  document.querySelectorAll('[data-mobile-link]').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      menu?.classList.remove('flex');
    });
  });
</script>
