---

<section id="especialidades" class="relative bg-gradient-to-br from-gray-50 via-white to-gray-100 py-24 px-6 overflow-hidden">
  <!-- Background accents -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-0 right-1/4 w-96 h-96 bg-gold/5 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 left-1/4 w-80 h-80 bg-navy/5 rounded-full blur-[100px]"></div>
  </div>

  <div class="max-w-6xl mx-auto relative">

    <!-- Section header -->
    <div class="text-center mb-16 reveal-enhanced">
      <span class="inline-block px-4 py-1.5 bg-navy/5 border border-navy/10 rounded-full text-navy font-sans font-medium text-xs tracking-widest uppercase mb-4">
        Especialización
      </span>
      <h2 class="font-serif text-gold text-3xl md:text-4xl lg:text-5xl font-bold mb-4 text-fluid">
        Áreas del derecho<br class="hidden md:block" />que defendemos
      </h2>
      <div class="gold-divider"></div>
      <p class="font-sans text-gray-600 text-lg max-w-2xl mx-auto">
        Nos especializamos exclusivamente en derecho penal, con experiencia en casos de alta complejidad.
      </p>
    </div>

    <!-- Cards grid con glassmorphism, 3D tilt y efectos premium -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {areas.map((area, idx) => (
        <div 
          class={`reveal-enhanced ${delays[idx] ?? ''} tilt-card group relative rounded-3xl p-6 transition-all duration-500 hover:-translate-y-2 glow-gold-hover gradient-border-animated`}
          style={`--tilt-x: 0deg; --tilt-y: 0deg;`}
          data-tilt-card
        >
          <!-- Gradient overlay on hover -->
          <div class="absolute inset-0 rounded-3xl bg-gradient-to-br from-gold/0 via-transparent to-gold/0 group-hover:from-gold/5 group-hover:to-gold/10 transition-all duration-500"></div>
          
          <!-- Icon con glow -->
          <div class="relative w-14 h-14 rounded-2xl bg-gradient-to-br from-navy to-navy/80 flex items-center justify-center text-gold mb-5 group-hover:scale-110 group-hover:shadow-lg group-hover:shadow-gold/30 transition-all duration-300">
            <span set:html={area.icon} />
          </div>

          <!-- Content -->
          <h3 class="relative font-serif text-white font-bold text-lg mb-2">{area.title}</h3>
          <p class="relative font-sans text-gray-300 text-sm leading-relaxed">{area.description}</p>

          <!-- Arrow indicator -->
          <div class="absolute bottom-6 right-6 w-8 h-8 rounded-full bg-gold/20 flex items-center justify-center opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all duration-300">
            <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<!-- 3D Tilt Script -->
<script>
  function initTiltCards() {
    const cards = document.querySelectorAll('[data-tilt-card]');
    
    cards.forEach(card => {
      const cardEl = card;
      
      cardEl.addEventListener('mousemove', (e) => {
        const rect = cardEl.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        
        const centerX = rect.width / 2;
        const centerY = rect.height / 2;
        
        const rotateX = (y - centerY) / centerY * -8;
        const rotateY = (x - centerX) / centerX * 6;
        
        cardEl.style.setProperty('--tilt-x', `${rotateX}deg`);
        cardEl.style.setProperty('--tilt-y', `${rotateY}deg`);
      });
      
      cardEl.addEventListener('mouseleave', () => {
        cardEl.style.setProperty('--tilt-x', '0deg');
        cardEl.style.setProperty('--tilt-y', '0deg');
      });
    });
  }

  // Initialize on load
  initTiltCards();
  
  // Re-init on view transitions
  document.addEventListener('astro:page-load', initTiltCards);
</script>