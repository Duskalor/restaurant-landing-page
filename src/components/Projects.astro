---
import { MessageSquare, ClipboardList, Lightbulb, Search, CloudSun, Paperclip } from '@lucide/astro';
import { projects } from '../data/portfolio';

const iconMap = { MessageSquare, ClipboardList, Lightbulb, Search, CloudSun, Paperclip };
---

<section id="projects" class="py-32">
  <div class="max-w-7xl mx-auto px-6">

    <div class="flex items-end justify-between mb-12">
      <div>
        <p class="text-xs font-semibold tracking-widest uppercase text-emerald-400 mb-4">03 — Work</p>
        <h2 class="text-5xl md:text-6xl font-black text-white leading-none">Projects</h2>
      </div>
      <p class="text-slate-600 text-sm hidden md:block tabular-nums">{projects.length} shipped</p>
    </div>

    <div class="grid md:grid-cols-2 gap-4">
      {projects.map((project, index) => {
        const Icon = iconMap[project.iconName];
        const isFeatured = index === 0;
        return (
          <article
            class:list={[
              "group relative backdrop-blur-xl bg-white/[0.04] border border-white/10 rounded-2xl flex flex-col transition-all duration-300 hover:bg-white/[0.07] hover:border-emerald-500/30 hover:shadow-lg hover:shadow-emerald-500/5 hover:-translate-y-0.5",
              { "md:col-span-2": isFeatured }
            ]}
            data-animate
            data-delay={index * 80}
          >
            {isFeatured ? (
              /* Featured card — horizontal layout */
              <div class="grid md:grid-cols-2 gap-0 h-full">
                <div class="p-10 flex flex-col justify-between border-b md:border-b-0 md:border-r border-white/10">
                  <div>
                    <div class="text-emerald-400 mb-6">
                      <Icon size={36} />
                    </div>
                    <h3 class="text-3xl font-black text-white mb-3">{project.title}</h3>
                    <p class="text-slate-400 leading-relaxed">{project.description}</p>
                  </div>
                  <div class="flex gap-4 mt-8">
                    {project.liveUrl && (
                      <a
                        href={project.liveUrl}
                        class="text-sm font-semibold text-emerald-400 hover:text-emerald-300 transition-colors"
                        target="_blank" rel="noopener noreferrer"
                      >
                        Live ↗
                      </a>
                    )}
                    {project.githubUrl && (
                      <a
                        href={project.githubUrl}
                        class="text-sm font-medium text-slate-400 hover:text-white transition-colors"
                        target="_blank" rel="noopener noreferrer"
                      >
                        GitHub ↗
                      </a>
                    )}
                  </div>
                </div>
                <div class="p-10 flex flex-col justify-end">
                  <p class="text-xs font-semibold tracking-widest uppercase text-slate-500 mb-4">Built with</p>
                  <div class="flex flex-wrap gap-2">
                    {project.technologies.map((tech) => (
                      <span class="px-3 py-1.5 bg-white/5 border border-white/10 text-slate-300 rounded-lg text-sm font-medium">
                        {tech}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            ) : (
              /* Regular card */
              <div class="p-8 flex flex-col h-full">
                <div class="flex items-start justify-between mb-6">
                  <div class="text-emerald-400">
                    <Icon size={28} />
                  </div>
                  <div class="flex gap-3">
                    {project.liveUrl && (
                      <a href={project.liveUrl} class="text-xs text-slate-400 hover:text-white transition-colors" target="_blank" rel="noopener noreferrer" aria-label="Live">↗ Live</a>
                    )}
                    {project.githubUrl && (
                      <a href={project.githubUrl} class="text-xs text-slate-400 hover:text-white transition-colors" target="_blank" rel="noopener noreferrer" aria-label="GitHub">↗ Code</a>
                    )}
                  </div>
                </div>
                <h3 class="text-xl font-bold text-white mb-2">{project.title}</h3>
                <p class="text-slate-400 text-sm leading-relaxed flex-grow mb-6">{project.description}</p>
                <div class="flex flex-wrap gap-1.5">
                  {project.technologies.map((tech) => (
                    <span class="px-2.5 py-1 bg-white/5 border border-white/10 text-slate-300 rounded-md text-xs font-medium">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>
            )}
          </article>
        );
      })}
    </div>

  </div>
</section>
