---
// T-10: Success Cases — modernizado con mejor diseño

const cases = [
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"/></svg>`,
    area: "Defensa en Juicio Oral",
    charge: "Homicidio Simple",
    description: "Cliente absuelto por falta de mérito tras cuestionamiento de la cadena de custodia probatoria.",
    result: "Absolución",
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 0010.5 21h3a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75"/></svg>`,
    area: "Medida Cautelar",
    charge: "Delito Económico",
    description: "Excarcelación obtenida dentro de las 48 hs mediante presentación de habeas corpus preventivo.",
    result: "Libertad en 48hs",
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg>`,
    area: "Apelación",
    charge: "Condena Reducida",
    description: "Reducción de pena del 60% en instancia de casación por errores procesales en la sentencia.",
    result: "Pena reducida 60%",
  },
];

const delays = ['delay-100', 'delay-200', 'delay-300'];
---

<section class="relative bg-gradient-to-br from-[#0D1B2A] via-[#0F1929] to-[#0D1B2A] py-24 px-6 overflow-hidden">
  <!-- Background elements -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-20 left-10 w-72 h-72 bg-gold/5 rounded-full blur-[100px]"></div>
    <div class="absolute bottom-20 right-10 w-96 h-96 bg-gold/3 rounded-full blur-[120px]"></div>
    <!-- Subtle grid pattern -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 60px 60px;"></div>
  </div>

  <div class="max-w-6xl mx-auto relative">

    <!-- Section header -->
    <div class="text-center mb-16 reveal">
      <span class="inline-block px-4 py-1.5 bg-gold/10 border border-gold/30 rounded-full text-gold font-sans font-medium text-xs tracking-widest uppercase mb-4">
        Casos de Éxito
      </span>
      <h2 class="font-serif text-white text-3xl md:text-4xl lg:text-5xl font-bold mb-6">
        Resultados que<br class="hidden md:block" />hablan por nosotros
      </h2>
      <p class="font-sans text-white/60 text-lg max-w-2xl mx-auto">
        Algunos de nuestros casos más representativos (anonimizados por confidencialidad).
      </p>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {cases.map((c, idx) => (
        <div class={`reveal ${delays[idx] ?? ''} group relative bg-white/5 backdrop-blur-sm border border-white/10 rounded-3xl p-8 hover:bg-white/10 hover:border-gold/30 transition-all duration-500 hover:-translate-y-2`}>
          <!-- Corner accent -->
          <div class="absolute top-0 right-0 w-16 h-16 overflow-hidden rounded-tr-3xl">
            <div class="absolute top-2 right-2 w-8 h-8 bg-gold/20 rounded-full group-hover:bg-gold/40 transition-colors duration-300"></div>
          </div>

          <!-- Icon -->
          <div class="w-14 h-14 rounded-2xl bg-gold/20 flex items-center justify-center text-gold mb-6 group-hover:bg-gold/30 group-hover:scale-110 transition-all duration-300">
            <span set:html={c.icon} />
          </div>

          <!-- Category -->
          <span class="font-sans text-gold text-xs font-medium tracking-widest uppercase mb-2 block">{c.area}</span>
          
          <!-- Charge -->
          <h3 class="font-serif text-white text-xl font-bold mb-4">{c.charge}</h3>

          <!-- Description -->
          <p class="font-sans text-white/60 text-sm leading-relaxed mb-6 flex-1">{c.description}</p>

          <!-- Result -->
          <div class="pt-4 border-t border-white/10">
            <div class="inline-flex items-center gap-2 px-4 py-2 bg-green-500/10 border border-green-500/20 rounded-full">
              <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="font-sans text-green-400 text-sm font-semibold">{c.result}</span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Disclaimer -->
    <p class="text-center text-white/30 font-sans text-xs mt-12 max-w-lg mx-auto leading-relaxed">
      Los casos se presentan de forma anonimizada para proteger la confidencialidad de nuestros clientes.
    </p>

  </div>
</section>