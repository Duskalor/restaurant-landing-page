---
// T-11: Team — attorney cards con fotos profesionales y efectos premium

const lawyers = [
  {
    image: "https://images.pexels.com/photos/7841788/pexels-photo-7841788.jpeg?auto=compress&cs=tinysrgb&w=400&h=500&fit=crop&q=80",
    name: "Dr. Carlos R. Castro",
    title: "Socio Fundador",
    specialty: "Defensa en juicio oral y delitos graves",
    experience: "20 años de experiencia",
    linkedin: "#",
  },
  {
    image: "https://images.pexels.com/photos/7959820/pexels-photo-7959820.jpeg?auto=compress&cs=tinysrgb&w=400&h=500&fit=crop&q=80",
    name: "Dra. Roxana C. Vargas",
    title: "Socia",
    specialty: "Delitos económicos y financieros",
    experience: "15 años de experiencia",
    linkedin: "#",
  },
  {
    image: "https://images.pexels.com/photos/16963942/pexels-photo-16963942.jpeg?auto=compress&cs=tinysrgb&w=400&h=500&fit=crop&q=80",
    name: "Dr. Marcelo P. Ibáñez",
    title: "Asociado Senior",
    specialty: "Recursos de apelación y casación",
    experience: "12 años de experiencia",
    linkedin: "#",
  },
];

const delays = ['delay-100', 'delay-200', 'delay-300'];
---

<section id="equipo" class="bg-gray-light py-24 px-6 relative overflow-hidden">
  <!-- Background accent -->
  <div class="absolute top-0 left-0 w-full h-32 bg-gradient-to-b from-white to-gray-light"></div>
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/4 right-1/4 w-64 h-64 bg-gold/5 rounded-full blur-[80px]"></div>
  </div>
  
  <div class="max-w-6xl mx-auto relative">

    <!-- Section header -->
    <div class="text-center mb-16 reveal-enhanced">
      <span class="inline-block px-4 py-1.5 bg-gold/10 border border-gold/30 rounded-full text-gold font-sans font-medium text-xs tracking-widest uppercase mb-4">
        Nuestro Equipo
      </span>
      <h2 class="font-serif text-navy text-3xl md:text-4xl lg:text-5xl font-bold mb-6 text-fluid">
        Abogados especializados en<br class="hidden md:block" />derecho penal
      </h2>
      <p class="font-sans text-text-dark/60 text-lg max-w-2xl mx-auto">
        Un equipo con más de 45 años de experiencia combinada defendiendo tus derechos.
      </p>
    </div>

    <!-- Cards con efecto glassmorphism, 3D tilt y glow -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {lawyers.map((lawyer, idx) => (
        <div 
          class={`reveal-enhanced ${delays[idx] ?? ''} tilt-card group relative bg-white/80 backdrop-blur-sm rounded-3xl overflow-hidden transition-all duration-500 hover:-translate-y-2 glow-gold-hover gradient-border-animated`}
          style="--tilt-x: 0deg; --tilt-y: 0deg;"
          data-tilt-card
        >
          <!-- Gradient border effect -->
          <div class="absolute inset-0 rounded-3xl p-px bg-gradient-to-br from-gold/50 via-transparent to-gold/20 -z-10"></div>
          
          <!-- Image -->
          <div class="relative h-72 overflow-hidden">
            <img 
              src={lawyer.image} 
              alt={lawyer.name}
              class="w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-110"
              loading="lazy"
            />
            <!-- Gradient overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-navy/60 via-transparent to-transparent"></div>
            
            <!-- Social badge -->
            <a
              href={lawyer.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="absolute top-4 right-4 w-10 h-10 bg-white/90 backdrop-blur-sm rounded-full flex items-center justify-center shadow-lg opacity-0 group-hover:opacity-100 transition-all duration-300 hover:scale-110"
              aria-label={`LinkedIn de ${lawyer.name}`}
            >
              <svg class="w-5 h-5 fill-[#0A66C2]" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          </div>

          <!-- Info -->
          <div class="p-6 relative">
            <!-- Accent line -->
            <div class="absolute top-0 left-6 right-6 h-0.5 bg-gradient-to-r from-gold to-yellow-300 transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500"></div>
            
            <h3 class="font-serif text-white text-xl font-bold mb-1">{lawyer.name}</h3>
            <p class="font-sans text-gold font-semibold text-sm mb-3">{lawyer.title}</p>
            <p class="font-sans text-gray-200 text-sm leading-relaxed mb-3">{lawyer.specialty}</p>
            
            <div class="flex items-center gap-2 text-gray-400 font-sans text-xs">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <span>{lawyer.experience}</span>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>