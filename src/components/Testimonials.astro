---
// T-12: Testimonials — 3 star-rated testimonials

const testimonials = [
  {
    initials: "M.G.",
    role: "Familiar de imputado",
    quote: "Desde el primer contacto nos transmitieron seguridad. Consiguieron la excarcelación en tiempo récord. Eternamente agradecidos.",
  },
  {
    initials: "R.T.",
    role: "Cliente",
    quote: "Profesionalismo y dedicación absoluta. Explicaron cada paso del proceso con claridad. El resultado superó nuestras expectativas.",
  },
  {
    initials: "L.F.",
    role: "Empresario",
    quote: "En una situación desesperante, encontramos en CRC Abogados la tranquilidad que necesitábamos. Equipo de primer nivel.",
  },
];

const stars = Array(5).fill(null);
const delays = ['delay-100', 'delay-200', 'delay-300'];
---

<section class="bg-[#0D1B2A] py-20 px-6">
  <div class="max-w-5xl mx-auto">

    <!-- Section header -->
    <div class="text-center mb-14 reveal">
      <p class="text-gold font-sans font-medium text-sm tracking-widest uppercase mb-3">Testimonios</p>
      <h2 class="font-serif text-white text-3xl md:text-4xl mb-4">Lo Que Dicen Nuestros Clientes</h2>
      <div class="gold-divider"></div>
    </div>

    <!-- Testimonials grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map((t, idx) => (
        <div class={`reveal ${delays[idx] ?? ''} glass-card rounded-2xl p-8 flex flex-col gap-5 relative overflow-hidden hover:border-gold/40 transition-colors duration-300`}>
          <!-- Large decorative quote mark -->
          <span class="absolute top-3 left-4 text-6xl font-serif text-gold/20 leading-none select-none" aria-hidden="true">"</span>

          <!-- Stars -->
          <div class="flex gap-1 relative z-10" aria-label="5 estrellas">
            {stars.map(() => (
              <svg class="w-4 h-4 text-gold fill-current" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <blockquote class="font-sans text-white/80 text-sm leading-relaxed flex-1 relative z-10 pt-2">
            {t.quote}
          </blockquote>

          <!-- Author -->
          <div class="flex items-center gap-3 pt-3 border-t border-white/10 relative z-10">
            <div class="w-9 h-9 rounded-full bg-gold/20 border border-gold/40 flex items-center justify-center shrink-0">
              <span class="font-sans text-gold text-xs font-semibold">{t.initials}</span>
            </div>
            <div>
              <p class="font-sans text-white text-sm font-semibold">{t.initials}</p>
              <p class="font-sans text-white/50 text-xs">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
