---
// T-16: WhatsApp floating button + Phone sticky bar
// Desktop: circular floating button bottom-right (WhatsApp only)
// Mobile (≤768px): full bottom bar with two tap targets: phone + WhatsApp
// TODO: replace phone numbers with real client numbers
const PHONE_NUMBER = "+5491140000000";
const PHONE_URL = `tel:${PHONE_NUMBER}`;
const WA_URL = "https://wa.me/5491140000000?text=Hola%2C%20necesito%20asesoramiento%20legal";
---

<!-- Desktop: floating circular button -->
<a
  href={WA_URL}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Contactar por WhatsApp"
  class="hidden md:flex fixed bottom-6 right-6 z-50 w-14 h-14 rounded-full bg-[#25D366] shadow-lg items-center justify-center hover:bg-[#20b857] hover:scale-110 active:scale-95 transition-all duration-200"
>
  <!-- Pulsing ring animation -->
  <span class="absolute inline-flex w-full h-full rounded-full bg-[#25D366] opacity-40 animate-ping"></span>

  <svg class="w-7 h-7 fill-white relative z-10" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
  </svg>
</a>

<!-- Mobile: full bottom sticky bar — two tap targets: phone + WhatsApp -->
<div class="md:hidden fixed bottom-0 left-0 right-0 z-50 flex shadow-[0_-2px_12px_rgba(0,0,0,0.2)]">
  <!-- Phone call button (left, 50%) — gold bg, navy text -->
  <a
    href={PHONE_URL}
    class="flex flex-1 items-center justify-center gap-2 py-4 px-3 min-h-[56px] bg-[#C9A84C] hover:bg-[#b8923e] active:bg-[#a07e34] transition-colors duration-150"
    aria-label="Llamar ahora"
  >
    <svg class="w-5 h-5 shrink-0 fill-[#0D1B2A]" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 011 1V20a1 1 0 01-1 1C10.61 21 3 13.39 3 4a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.46.57 3.58a1 1 0 01-.25 1.01l-2.2 2.2z"/>
    </svg>
    <span class="font-sans text-[#0D1B2A] font-semibold text-sm leading-tight">Llamar ahora</span>
  </a>

  <!-- WhatsApp button (right, 50%) — WhatsApp green -->
  <a
    href={WA_URL}
    target="_blank"
    rel="noopener noreferrer"
    class="flex flex-1 items-center justify-center gap-2 py-4 px-3 min-h-[56px] bg-[#25D366] hover:bg-[#20b857] active:bg-[#1da04d] transition-colors duration-150"
    aria-label="Contactar por WhatsApp"
  >
    <svg class="w-5 h-5 shrink-0 fill-white" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
    <span class="font-sans text-white font-semibold text-sm leading-tight">WhatsApp</span>
  </a>
</div>
