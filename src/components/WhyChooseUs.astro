---
import { getWhyChooseUs } from '../lib/sanity'
import { useTranslations } from '../i18n/index'
import type { Locale } from '../i18n/index'

interface Props {
  lang?: Locale;
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);

const FALLBACK_ITEMS = [
  {
    icon: '🧭',
    title: lang === 'en' ? 'Certified local guides' : lang === 'pt' ? 'Guias locais certificados' : 'Guías locales certificados',
    description: lang === 'en' ? 'Over 10 years of experience in the Andes' : lang === 'pt' ? 'Mais de 10 anos de experiência nos Andes' : 'Más de 10 años de experiencia en los Andes',
  },
  {
    icon: '💰',
    title: lang === 'en' ? 'Transparent pricing' : lang === 'pt' ? 'Preço transparente' : 'Precio transparente',
    description: lang === 'en' ? 'No hidden costs or surprises' : lang === 'pt' ? 'Sem custos ocultos ou surpresas' : 'Sin costos ocultos ni sorpresas',
  },
  {
    icon: '📱',
    title: 'WhatsApp 24/7',
    description: lang === 'en' ? 'We respond in less than 2 hours' : lang === 'pt' ? 'Respondemos em menos de 2 horas' : 'Respondemos en menos de 2 horas',
  },
  {
    icon: '🌿',
    title: lang === 'en' ? 'Responsible tourism' : lang === 'pt' ? 'Turismo responsável' : 'Turismo responsable',
    description: lang === 'en' ? 'Ethical practices with local communities' : lang === 'pt' ? 'Práticas éticas com as comunidades locais' : 'Prácticas éticas con las comunidades locales',
  },
  {
    icon: '✅',
    title: lang === 'en' ? 'Flexible cancellation' : lang === 'pt' ? 'Cancelamento flexível' : 'Cancelación flexible',
    description: lang === 'en' ? 'Free changes up to 48h before' : lang === 'pt' ? 'Mudanças gratuitas até 48h antes' : 'Cambios sin costo hasta 48hs antes',
  },
  {
    icon: '🏆',
    title: lang === 'en' ? 'Certified' : lang === 'pt' ? 'Certificados' : 'Certificados',
    description: lang === 'en' ? 'MINCETUR and international organizations' : lang === 'pt' ? 'MINCETUR e organismos internacionais' : 'MINCETUR y organismos internacionales',
  },
]

const data = await getWhyChooseUs(lang)
const title = data?.title || t.whyUs.defaultTitle
const items = (data?.items && data.items.length > 0) ? data.items : FALLBACK_ITEMS
---

<section id="por-que-elegirnos" class="py-16 md:py-24" style="background-color: var(--color-bg)">
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    <!-- Header -->
    <div class="text-center mb-16">
      <p class="text-sm font-medium tracking-widest uppercase mb-3" style="color: var(--color-accent)">
        {t.whyUs.label}
      </p>
      <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold mb-4 reveal" style="color: var(--color-text)">
        {title}
      </h2>
      <p class="max-w-lg mx-auto" style="color: var(--color-muted)">
        {t.whyUs.subtitle}
      </p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {items.map((item, i) => (
        <div
          class={`flex items-start gap-4 reveal${i === 1 ? ' reveal-delay-1' : i === 2 ? ' reveal-delay-2' : i === 3 ? ' reveal-delay-3' : ''}`}
        >
          <!-- Icon circle -->
          <div
            class="flex-shrink-0 w-12 h-12 rounded-full flex items-center justify-center text-2xl"
            style="background-color: var(--color-accent); opacity: 0.9;"
          >
            {item.icon}
          </div>

          <!-- Text -->
          <div>
            <h3 class="font-semibold text-base mb-1" style="color: var(--color-text)">{item.title}</h3>
            <p class="text-sm leading-relaxed" style="color: var(--color-muted)">{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
