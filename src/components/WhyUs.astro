---
// T-09: Why Us — 5 differentiators

const differentiators = [
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"/></svg>`,
    title: "Experiencia comprobada",
    description: "15+ años de ejercicio exclusivo en materia penal. No somos generalistas: el derecho penal es nuestra única especialidad.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"/></svg>`,
    title: "Disponibilidad inmediata",
    description: "Línea de emergencia activa las 24 horas, los 7 días. Actuamos de forma urgente ante detenciones y allanamientos.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/></svg>`,
    title: "Confidencialidad absoluta",
    description: "Protocolo de comunicación segura y secreto profesional garantizado desde el primer contacto.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
    title: "Estrategia personalizada",
    description: "Cada caso es único. Diseñamos un plan de defensa a medida, sin soluciones genéricas.",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>`,
    title: "Equipo multidisciplinario",
    description: "Abogados, peritos forenses y consultores especializados trabajando en conjunto por tu defensa.",
  },
];

const rowDelays = ['delay-100', 'delay-200', 'delay-300', 'delay-400', 'delay-500'];
---

<section class="bg-white py-20 px-6 overflow-hidden">
  <div class="max-w-5xl mx-auto">

    <div class="flex flex-col lg:flex-row gap-12 lg:gap-16">

      <!-- Left column: sticky section header -->
      <div class="lg:w-2/5 reveal-left">
        <div class="lg:sticky lg:top-24">
          <!-- Vertical gold accent line (desktop) -->
          <div class="hidden lg:block w-px h-16 bg-gradient-to-b from-gold to-gold/20 mb-6"></div>

          <p class="text-gold font-sans font-medium text-sm tracking-widest uppercase mb-3">Nuestros diferenciales</p>
          <h2 class="font-serif text-navy text-3xl md:text-4xl mb-4">¿Por Qué Elegirnos?</h2>
          <div class="gold-divider" style="margin: 0 0 1.5rem;"></div>
          <p class="font-sans text-text-dark/60 text-base leading-relaxed">
            En CRC Abogados Asociados, cada detalle importa. Combinamos experiencia, estrategia y dedicación absoluta para proteger tus derechos.
          </p>
        </div>
      </div>

      <!-- Right column: feature rows -->
      <div class="lg:w-3/5 flex flex-col gap-3">
        {differentiators.map((item, idx) => (
          <div class={`reveal-right ${rowDelays[idx] ?? ''} flex gap-4 p-5 rounded-xl hover:bg-gray-50 transition-colors duration-200`}>
            <div class="w-12 h-12 rounded-full bg-navy flex items-center justify-center text-gold shrink-0">
              <span set:html={item.icon} />
            </div>
            <div class="flex flex-col gap-1 justify-center">
              <h3 class="font-serif text-navy text-lg font-semibold">{item.title}</h3>
              <p class="font-sans text-text-dark/70 text-sm leading-relaxed">{item.description}</p>
            </div>
          </div>
        ))}
      </div>

    </div>

  </div>
</section>
