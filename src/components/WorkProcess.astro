---
// T-13: Work Process — 5-step timeline

const steps = [
  {
    number: "01",
    title: "Contacto inicial",
    description: "Llamada o formulario confidencial. Sin costo ni compromiso.",
  },
  {
    number: "02",
    title: "Evaluación del caso",
    description: "Reunión privada para analizar la situación jurídica en detalle.",
  },
  {
    number: "03",
    title: "Estrategia de defensa",
    description: "Diseño del plan legal personalizado con objetivos claros.",
  },
  {
    number: "04",
    title: "Ejecución y seguimiento",
    description: "Representación activa con reportes periódicos al cliente.",
  },
  {
    number: "05",
    title: "Resolución",
    description: "Acompañamiento hasta la resolución definitiva del caso.",
  },
];

const delays = ['delay-100', 'delay-200', 'delay-300', 'delay-400', 'delay-500'];
---

<section class="bg-white py-20 px-6">
  <div class="max-w-5xl mx-auto">

    <!-- Section header -->
    <div class="text-center mb-16 reveal">
      <p class="text-gold font-sans font-medium text-sm tracking-widest uppercase mb-3">Metodología</p>
      <h2 class="font-serif text-navy text-3xl md:text-4xl mb-4">¿Cómo Trabajamos?</h2>
      <div class="gold-divider"></div>
    </div>

    <!-- Timeline — horizontal on md+, vertical on mobile -->
    <div class="relative">

      <!-- Horizontal connector gradient line (desktop only) -->
      <div class="hidden md:block absolute top-7 left-[10%] right-[10%] h-0.5 bg-gradient-to-r from-gold/30 via-gold to-gold/30"></div>

      <div class="grid grid-cols-1 md:grid-cols-5 gap-10 md:gap-4">
        {steps.map((step, idx) => (
          <div class={`reveal ${delays[idx] ?? ''} relative flex md:flex-col items-start md:items-center gap-5 md:gap-4 text-left md:text-center`}>

            <!-- Mobile: vertical gold line between steps -->
            {idx < steps.length - 1 && (
              <div class="md:hidden absolute left-[27px] top-16 w-0.5 h-[calc(100%+2.5rem)] bg-gradient-to-b from-gold/60 to-gold/20"></div>
            )}

            <!-- Number circle — larger with ring and shadow -->
            <div class="relative z-10 w-14 h-14 rounded-full bg-gold flex items-center justify-center shrink-0 ring-4 ring-gold/20 shadow-lg shadow-gold/20">
              <span class="font-sans text-navy text-xs font-bold">{step.number}</span>
            </div>

            <!-- Content: glass card on desktop -->
            <div class="md:bg-gray-50 md:border md:border-gray-100 md:rounded-xl md:p-3 flex flex-col gap-1 w-full">
              <h3 class="font-serif text-navy text-base font-semibold">{step.title}</h3>
              <p class="font-sans text-text-dark/60 text-sm leading-relaxed">{step.description}</p>
            </div>

          </div>
        ))}
      </div>
    </div>

  </div>
</section>
