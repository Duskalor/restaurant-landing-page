---
import '../styles/global.css';
import SEO from '../components/SEO.astro';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0D1B2A" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- SEO: title, description, canonical, OG, Twitter Card -->
    <SEO title={title} description={description} />

    <!-- Google Fonts: preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Google Fonts: Playfair Display + Inter -->
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD: LegalService + Attorney schema -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "LegalService",
        "name": "CRC Abogados Asociados",
        "description": "Estudio jurídico especializado en derecho penal en Perú. Más de 15 años de experiencia.",
        "url": "https://crcabogados.com.pe",
        "telephone": "+51-84-000-0000",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Cusco",
          "addressCountry": "PE"
        },
        "areaServed": "PE",
        "serviceType": "Criminal Defense",
        "knowsAbout": ["Derecho Penal", "Defensa Criminal", "Juicio Oral", "Habeas Corpus"],
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Servicios Legales Penales"
        },
        "employee": [
          {
            "@type": "Attorney",
            "name": "Dr. Carlos R. Castro",
            "jobTitle": "Abogado Penalista"
          }
        ]
      }
    </script>

    <!-- Google Analytics 4 via Partytown -->
    <script type="text/partytown" async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script type="text/partytown">
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script>
  </head>
  <body>
    <slot />

    <script>
      // Reduced motion detection
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.documentElement.classList.add('reduce-motion');
      }

      // Scroll reveal (including enhanced)
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(el => {
          if (el.isIntersecting) {
            el.target.classList.add('visible');
          }
        });
      }, { threshold: 0.12 });
      document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-enhanced').forEach(el => revealObserver.observe(el));

      // Parallax effect
      const parallaxObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          const element = entry.target;
          const speed = parseFloat(element.dataset.parallaxSpeed || '0.3');
          
          if (entry.isIntersecting) {
            const rect = element.getBoundingClientRect();
            const viewportHeight = window.innerHeight;
            const elementTop = rect.top;
            const elementHeight = rect.height;
            
            // Calculate parallax offset
            const offset = (viewportHeight - elementTop) * speed;
            element.style.setProperty('--parallax-offset', `${offset * 0.3}px`);
          }
        });
      }, { threshold: 0 });
      
      document.querySelectorAll('.parallax-blob').forEach(el => parallaxObserver.observe(el));

      // Update parallax on scroll
      let ticking = false;
      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            document.querySelectorAll('.parallax-blob').forEach(el => {
              const element = el;
              const rect = element.getBoundingClientRect();
              const speed = parseFloat(element.dataset.parallaxSpeed || '0.3');
              const viewportHeight = window.innerHeight;
              const offset = (viewportHeight - rect.top) * speed;
              element.style.setProperty('--parallax-offset', `${offset * 0.3}px`);
            });
            ticking = false;
          });
          ticking = true;
        }
      });
    </script>
  </body>
</html>
