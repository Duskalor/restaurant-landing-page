---
import Layout from '../layouts/Layout.astro'
import Navbar from '../components/Navbar.astro'
import Footer from '../components/Footer.astro'
import { getSiteSettings } from '../lib/sanity'

const settings = await getSiteSettings()
const restaurantName = settings?.restaurantName ?? 'Restaurante'
---

<Layout
  title={`Página no encontrada — ${restaurantName}`}
  description="La página que buscás no existe. Volvé al inicio y explorá nuestros tours."
>
  <Navbar />
  <main class="min-h-screen flex items-center justify-center bg-[var(--color-bg)] pt-16">
    <div class="text-center px-6 py-24">
      <p class="text-[var(--color-primary)] text-sm font-medium tracking-widest uppercase mb-4">
        Error 404
      </p>
      <h1 class="font-serif text-6xl md:text-8xl font-bold text-[var(--color-text)] mb-4">
        404
      </h1>
      <p class="font-serif text-2xl md:text-3xl text-[var(--color-text)] mb-4">
        Esta página no existe
      </p>
      <p class="text-[var(--color-muted)] text-base md:text-lg max-w-md mx-auto mb-10 leading-relaxed">
        La página que buscás no fue encontrada. Quizás fue movida o simplemente nunca existió.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/"
          class="inline-block px-8 py-3.5 bg-[var(--color-primary)] text-white font-medium rounded hover:bg-[var(--color-primary-dark)] transition-colors duration-200"
        >
          Volver al inicio
        </a>
        <a
          href="/tours"
          class="inline-block px-8 py-3.5 border border-[var(--color-text)] text-[var(--color-text)] font-medium rounded hover:bg-[var(--color-text)] hover:text-white transition-colors duration-200"
        >
          Ver los tours
        </a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
