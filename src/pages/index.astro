---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import TourCategories from '../components/TourCategories.astro';
import FeaturedTours from '../components/FeaturedTours.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import Certifications from '../components/Certifications.astro';
import Gallery from '../components/Gallery.astro';
import Testimonials from '../components/Testimonials.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import { getSiteSettings } from '../lib/sanity';

const settings = await getSiteSettings();
const agencyName = settings?.restaurantName ?? 'Agencia de Turismo';
---

<Layout
  title={`${agencyName} — Tours en Cusco y los Andes`}
  description='Agencia de turismo en Cusco, Perú. Tours al Camino Inca, Machu Picchu, Valle Sagrado y más. Guías locales certificados, precios transparentes y turismo responsable.'
>
  <Navbar />
  <main>
    <Hero />
    <TourCategories />
    <FeaturedTours />
    <WhyChooseUs />
    <Certifications />
    <Gallery />
    <Testimonials />
    <Contact />
  </main>
  <Footer />
</Layout>
