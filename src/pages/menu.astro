---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getMenuItems, getSiteSettings, urlFor } from '../lib/sanity';

const categoryLabels: Record<string, string> = {
  entrada: 'Entradas',
  principal: 'Platos principales',
  postre: 'Postres',
  bebida: 'Bebidas',
};

const categoryOrder = ['entrada', 'principal', 'postre', 'bebida'];

const settings = await getSiteSettings();
const restaurantName = settings?.restaurantName ?? 'Restaurante';

const allItems = await getMenuItems();

const grouped = categoryOrder.reduce((acc, cat) => {
  const items = allItems.filter((i) => i.category === cat);
  if (items.length > 0) acc[cat] = items;
  return acc;
}, {} as Record<string, typeof allItems>);
---

<Layout title={`Menú — ${restaurantName}`} description={`Descubre todas las especialidades de ${restaurantName}. Entradas, platos principales, postres y bebidas con ingredientes de temporada.`}>
  <Navbar />
  <main class="pt-24 pb-16 md:pb-24 bg-[#FAFAF7] min-h-screen">
    <div class="max-w-7xl mx-auto px-4 md:px-6">

      <!-- Header -->
      <div class="text-center mb-16">
        <p class="text-[#C9A96E] text-sm font-medium tracking-widest uppercase mb-3">
          Nuestra cocina
        </p>
        <h1 class="font-serif text-4xl md:text-5xl font-bold text-[#2C2C2C] mb-4">
          Menú completo
        </h1>
        <p class="text-[#6B6B6B] max-w-lg mx-auto">
          Todos nuestros platos elaborados con ingredientes de temporada y técnica impecable.
        </p>
        <a href="/" class="inline-block mt-6 text-sm text-[#C9A96E] hover:underline">
          ← Volver al inicio
        </a>
      </div>

      <!-- Categories -->
      {Object.entries(grouped).map(([cat, items]) => (
        <div class="mb-16">
          <h2 class="font-serif text-2xl font-bold text-[#2C2C2C] mb-8 pb-3 border-b border-[#E8E0D0]">
            {categoryLabels[cat]}
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 md:gap-8">
            {items.map((item) => (
              <article class="bg-white border border-[#E8E0D0] rounded-sm overflow-hidden group hover:shadow-md transition-shadow duration-300">
                {item.image && (
                  <div class="overflow-hidden h-44 sm:h-52">
                    <img
                      src={urlFor(item.image).width(400).height(208).format('webp').url()}
                      alt={item.imageAlt || item.name}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      loading="lazy"
                    />
                  </div>
                )}
                <div class="p-5">
                  <h3 class="font-serif text-lg font-bold text-[#2C2C2C] mb-2">{item.name}</h3>
                  <p class="text-sm text-[#6B6B6B] leading-relaxed mb-4">{item.description}</p>
                  <p class="font-serif text-xl font-bold text-[#C9A96E]">S/. {Number(item.price).toFixed(2)}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      ))}

    </div>
  </main>
  <Footer />
</Layout>
