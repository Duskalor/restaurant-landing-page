---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import About from '../components/About.astro';
import Footer from '../components/Footer.astro';
import { getSiteSettings } from '../lib/sanity';

const settings = await getSiteSettings();
const restaurantName = settings?.restaurantName ?? 'Restaurante';
---

<Layout title={`Nosotros — ${restaurantName}`} description={`Conoce la historia de ${restaurantName}, nuestro equipo de guías certificados y la historia detrás de ${restaurantName}.`}>
  <Navbar />
  <main class="pt-16">
    <About />
  </main>
  <Footer />
</Layout>
