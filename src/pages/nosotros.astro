---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import About from '../components/About.astro';
import Footer from '../components/Footer.astro';
import { getSiteSettings } from '../lib/sanity';

const settings = await getSiteSettings();
const businessName = settings?.businessName ?? 'Restaurante';
---

<Layout title={`Nosotros — ${businessName}`} description={`Conoce la historia de ${businessName}, nuestra pasión por la gastronomía y los chefs que hacen posible cada experiencia única.`}>
  <Navbar />
  <main class="pt-16">
    <About />
  </main>
  <Footer />
</Layout>
